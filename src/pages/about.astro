---
// src/pages/about.astro
// 终极自由长卷版：彻底解除屏幕高度锁死，释放原生丝滑滚动与完整文献显影
import '../styles/global.css';
import FloatingButton from '../components/FloatingButton.astro';
import PureTransition from '../components/PureTransition.astro';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>About // ZHAO WENHAO</title>
  <script src="/scripts/font-loader.js" is:inline></script>
</head>
<body class="min-h-screen w-full bg-[#050505] text-neutral-100 font-mono select-none flex flex-col md:flex-row relative" style="margin: 0; padding: 0; background-color: #050505;">
  <PureTransition />

  <canvas id="terminal-grid" class="absolute inset-0 block w-full h-full z-0 pointer-events-none opacity-20"></canvas>

  <div class="w-full md:w-[40%] border-b md:border-b-0 md:border-r border-neutral-800 p-8 md:p-12 flex flex-col justify-between shrink-0 bg-[#0a0a0a] z-20 relative overflow-hidden" style="background-color: #0a0a0a;">
    
    <div class="absolute inset-0 z-0 opacity-35 grayscale hover:opacity-85 hover:grayscale-0 transition-all duration-700 pointer-events-auto">
      <img src="/main-picture.jpg" alt="Zhao Wenhao Portrait" class="w-full h-full object-cover" onerror="this.style.display='none'">
    </div>

    <div class="relative z-10 pointer-events-none">
      <div class="text-[#8EDB35] text-xs tracking-[0.4em] font-bold">// CYBERNETIC_SHELL</div>
      <h1 class="text-white text-5xl md:text-7xl font-black tracking-tighter mt-4 leading-none" style="color: #ffffff;">
        赵文浩<br/>WENHAO
      </h1>
      <div class="mt-4 inline-block bg-[#050505] px-3 py-1.5 border border-[#8EDB35]/40 text-[#8EDB35] text-xs tracking-widest font-bold" style="color: #8EDB35; background-color: #050505;">
        [ 男 / 19岁 / 25级本科生 ]
      </div>
    </div>

    <div class="relative z-10 space-y-2 my-12 md:my-32 pointer-events-none">
      <div class="text-neutral-500 text-[10px] tracking-widest uppercase" style="color: #737373;">// ACADEMIC_AFFILIATION:</div>
      <div class="text-white text-xs md:text-sm font-bold tracking-widest leading-relaxed" style="color: #e5e5e5;">
        北京师范大学珠海校区<br/>
        未来设计学院 // School of Future Design
      </div>
    </div>

    <div class="relative z-10 pt-4 pointer-events-auto">
      <a href="/hub" class="text-neutral-500 hover:text-[#8EDB35] text-xs tracking-widest font-bold transition-colors" style="color: #737373;">
        ← RETURN_TO_HUB
      </a>
    </div>
  </div>

  <div class="w-full md:w-[60%] p-8 md:p-16 z-10 bg-[#080808] relative pointer-events-auto" style="background-color: #080808;">
    <div class="max-w-xl mx-auto space-y-16 md:space-y-20 pb-24 pt-4 md:pt-0">

      <section class="space-y-8">
        <div class="flex items-center gap-2 text-[#8EDB35] text-xs tracking-widest font-bold border-b border-neutral-800 pb-2">
          <span class="w-1.5 h-1.5 bg-[#8EDB35]"></span>
          <span>// 01. EDITORIAL_CREDO</span>
        </div>
        
        <div class="space-y-8">
          <div class="relative pl-6 border-l-2 border-[#8EDB35]">
            <p class="text-white text-xl md:text-2xl font-black italic tracking-tight leading-snug" style="color: #ffffff;">
              “Make something different.”
            </p>
            <p class="text-neutral-500 text-xs mt-2" style="color: #737373;">— 这是我初中时一位好友常对我说的话</p>
          </div>
          
          <div class="relative pl-6 border-l-2 border-neutral-700">
             <p class="text-white text-xl md:text-2xl font-black italic tracking-tight leading-snug" style="color: #ffffff;">
              “Integrate thinking into design.”
            </p>
            <p class="text-neutral-500 text-xs mt-2" style="color: #737373;">— 这是我时刻提醒自己的信条</p>
          </div>

          <div class="p-5 bg-[#0f0f0f] border border-neutral-800/80 rounded-sm mt-6" style="background-color: #0f0f0f;">
            <p class="text-neutral-300 text-xs md:text-sm leading-relaxed" style="color: #d4d4d4;">
              如今，这两句话已成为我做设计最核心的理念。它们彼此呼应、相辅相成，让我在<span class="text-[#8EDB35] font-bold" style="color: #8EDB35;">先锋与人文</span>之间，找到属于自己的平衡点。
            </p>
          </div>
        </div>
      </section>

      <section class="relative group">
        <div class="flex justify-between items-center text-neutral-600 text-[10px] tracking-widest mb-2" style="color: #737373;">
          <span>[ VISUAL_PLATE // 01 ]</span>
          <span>KINETIC_EXPERIMENT</span>
        </div>
        
        <div class="relative border border-neutral-800 p-2 overflow-hidden bg-[#0d0d0d] rounded-sm" style="background-color: #0d0d0d;">
          <div class="absolute inset-x-0 top-0 h-[2px] bg-[#8EDB35] z-20 opacity-0 group-hover:opacity-100 group-hover:animate-scan pointer-events-none"></div>
          
          <img src="/second-picture.jpg" alt="Zhao Wenhao Kinetic Action" class="w-full max-h-[450px] object-cover grayscale group-hover:grayscale-0 transition-all duration-500" onerror="this.style.display='none'">
          
          <div class="absolute bottom-4 right-4 bg-[#8EDB35] text-[#0a0a0a] text-[9px] px-2 py-1 font-black tracking-widest" style="background-color: #8EDB35; color: #050505;">
            ACTION_FREEZE
          </div>
        </div>
      </section>

      <section class="space-y-6">
        <div class="text-[#8EDB35] text-xs tracking-widest font-bold" style="color: #8EDB35;">// 02. RESEARCH_FIELDS</div>
        
        <div class="grid grid-cols-1 gap-3">
          <div class="p-5 bg-[#0f0f0f] border border-neutral-800/80 flex justify-between items-center hover:border-[#8EDB35] transition-colors" style="background-color: #0f0f0f;">
            <span class="text-white font-black text-sm md:text-base tracking-wide" style="color: #ffffff;">实验艺术 // Experimental Art</span>
            <span class="text-neutral-600 font-bold text-xs" style="color: #525252;">01</span>
          </div>
          <div class="p-5 bg-[#0f0f0f] border border-neutral-800/80 flex justify-between items-center hover:border-[#8EDB35] transition-colors" style="background-color: #0f0f0f;">
            <span class="text-white font-black text-sm md:text-base tracking-wide" style="color: #ffffff;">人机交互 // HCI</span>
            <span class="text-neutral-600 font-bold text-xs" style="color: #525252;">02</span>
          </div>
          <div class="p-5 bg-[#0f0f0f] border border-neutral-800/80 flex justify-between items-center hover:border-[#8EDB35] transition-colors" style="background-color: #0f0f0f;">
            <span class="text-white font-black text-sm md:text-base tracking-wide" style="color: #ffffff;">游戏设计 // Game Design</span>
            <span class="text-neutral-600 font-bold text-xs" style="color: #525252;">03</span>
          </div>
        </div>
      </section>

      <section class="space-y-6">
        <div class="text-[#8EDB35] text-xs tracking-widest font-bold" style="color: #8EDB35;">// 03. DAILY_FREQUENCY</div>
        
        <div class="grid grid-cols-2 gap-3">
          <div class="p-4 border border-neutral-900 bg-[#0a0a0a] text-center rounded-sm" style="background-color: #0a0a0a;">
            <div class="text-neutral-600 text-[9px] mb-1" style="color: #525252;">FREQ_01</div>
            <div class="text-white text-xs font-bold tracking-widest" style="color: #ffffff;">阅读 / READING</div>
          </div>
          <div class="p-4 border border-neutral-900 bg-[#0a0a0a] text-center rounded-sm" style="background-color: #0a0a0a;">
            <div class="text-neutral-600 text-[9px] mb-1" style="color: #525252;">FREQ_02</div>
            <div class="text-white text-xs font-bold tracking-widest" style="color: #ffffff;">听音乐 / MUSIC</div>
          </div>
          <div class="p-4 border border-neutral-900 bg-[#0a0a0a] text-center rounded-sm" style="background-color: #0a0a0a;">
            <div class="text-neutral-600 text-[9px] mb-1" style="color: #525252;">FREQ_03</div>
            <div class="text-white text-xs font-bold tracking-widest" style="color: #ffffff;">吉他练习 / GUITAR</div>
          </div>
          <div class="p-4 border border-neutral-900 bg-[#0a0a0a] text-center rounded-sm" style="background-color: #0a0a0a;">
            <div class="text-neutral-600 text-[9px] mb-1" style="color: #525252;">FREQ_04</div>
            <div class="text-white text-xs font-bold tracking-widest" style="color: #ffffff;">ACG_CULTURE</div>
          </div>
        </div>
      </section>

      <section class="pt-6">
        <div class="p-6 bg-[#8EDB35] text-[#0a0a0a] font-black italic relative overflow-hidden flex justify-between items-center rounded-sm" style="background-color: #8EDB35;">
          <div class="relative z-10">
            <div class="text-[10px] mb-1 font-bold not-italic tracking-widest" style="color: #050505;">// CURRENT_EVOLUTION_STATE:</div>
            <div class="text-base md:text-lg tracking-tight leading-relaxed" style="color: #050505;">
              Unity 学习中～<br/>
              Vibe Coding 学习中～
            </div>
          </div>
          
          <div class="relative z-10 opacity-20">
            <svg class="w-16 h-16 text-[#0a0a0a]" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
            </svg>
          </div>
        </div>
      </section>

      <div class="text-center pt-16 text-neutral-700 text-[10px] tracking-[0.4em]" style="color: #525252;">
        // ZHAO_WENHAO_ARCHIVE_EOF //
      </div>

    </div>
  </div>

  <script>
    // 动态调整画布尺寸，彻底放行底部滚动
    const canvas = document.getElementById('terminal-grid') as HTMLCanvasElement;
    canvas.style.visibility = 'hidden';
    const ctx = canvas.getContext('2d')!;
    
    function resize() {
      // 获取整个文档的实际流动高度，而非单一屏幕高度
      canvas.width = document.body.clientWidth; 
      canvas.height = Math.max(document.body.clientHeight, window.innerHeight);
    }
    window.addEventListener('resize', resize);
    // 延迟执行确保内部图文流完全撑开后再覆盖背景网格
    setTimeout(resize, 100);

    let offset = 0;
    function animate() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      ctx.strokeStyle = '#121212';
      ctx.lineWidth = 1;
      
      const spacing = 50;
      offset = (offset + 0.2) % spacing;

      for (let x = offset; x < canvas.width; x += spacing) {
        ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, canvas.height); ctx.stroke();
      }
      for (let y = offset; y < canvas.height; y += spacing) {
        ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(canvas.width, y); ctx.stroke();
      }
      
      requestAnimationFrame(animate);
    }
    // 等待字体加载完毕再开始绘制，避免 canvas 使用回退字体。
    if (window.fontsReadyPromise) {
      window.fontsReadyPromise.then(() => { canvas.style.visibility = 'visible'; animate(); });
    } else if (document.fonts && document.fonts.ready) {
      document.fonts.ready.then(() => { canvas.style.visibility = 'visible'; animate(); });
    } else {
      // 兜底：直接启动
      canvas.style.visibility = 'visible';
      animate();
    }
  </script>

  <style>
    @keyframes scan {
      0% { top: 0%; opacity: 1; }
      95% { top: 100%; opacity: 1; }
      100% { top: 100%; opacity: 0; }
    }
    .animate-scan {
      animation: scan 1.8s linear infinite;
      box-shadow: 0 0 12px #8EDB35;
    }
  </style>
</body>
<FloatingButton /> </body>
</html>