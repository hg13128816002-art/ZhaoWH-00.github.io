---
// src/pages/hub.astro
import '../styles/global.css';
import LiquidNavHub from '../components/LiquidNavHub.astro';
import PureTransition from '../components/PureTransition.astro';
import HomeButton from '../components/HomeButton.astro';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Liquid Navigation Hub</title>
  <link rel="preload" href="/fonts/NotoSansSC-Regular.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/fonts/NotoSansSC-Bold.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/fonts/NotoSansSC-Black.woff2" as="font" type="font/woff2" crossorigin>
  <script src="/scripts/font-loader.js" is:inline></script>
</head>
<body class="w-screen h-screen overflow-hidden m-0 p-0 bg-[#0a0a0a]">
  <PureTransition />
  <LiquidNavHub />
  <HomeButton />
</body>
</html>
