---
// src/pages/index.astro
// 终极无Bug生产版：严密三体 Staggered 宇宙 + 绝对单层信仰环 + 完美字符朝向 (头顶指心)
import '../styles/global.css';
import Preloader from '../components/Preloader.astro';
import PureTransition from '../components/PureTransition.astro';
import SiteHeader from '../components/SiteHeader.astro';
---

<style>
  @import url('https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700&display=swap');

  :root {
    --stable-app-height: 100vh;
  }
  
  .font-mono {
    font-family: var(--font-mono-cn) !important;
  }

  #home-hero {
    contain: paint;
  }

  .hero-title-stack {
    font-family: var(--font-sans-cn);
    transform: translateY(clamp(-2.9rem, -5.2vh, -1.7rem));
  }

  .hero-dot {
    animation: heroDotBlink 1.05s steps(2, start) infinite;
    display: inline-block;
  }

  @keyframes heroDotBlink {
    0%, 48% {
      opacity: 1;
    }

    49%, 100% {
      opacity: 0;
    }
  }
</style>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ZHAO WENHAO // PORTFOLIO</title>
  <link rel="preload" href="/fonts/NotoSansSC-Regular.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/fonts/NotoSansSC-Bold.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/fonts/NotoSansSC-Black.woff2" as="font" type="font/woff2" crossorigin>
  <script src="/scripts/font-loader.js" is:inline></script>
  <script type="importmap" is:inline>
    {
      "imports": {
        "three": "https://unpkg.com/three@0.165.0/build/three.module.js",
        "three/addons/": "https://unpkg.com/three@0.165.0/examples/jsm/"
      }
    }
  </script>
</head>
<body class="w-full min-h-screen bg-[#050505] overflow-x-hidden select-none relative" style="margin: 0; padding: 0; background-color: #050505;">
  <PureTransition />
  <SiteHeader />
  <Preloader />

  <section id="home-hero" class="relative w-full h-screen overflow-hidden">
  <div class="absolute inset-0 z-0 pointer-events-none overflow-hidden flex flex-col justify-center opacity-25">
    <div class="w-[280vw] -translate-x-[80vw] rotate-[-24deg] flex flex-col gap-2 select-none">
      <div class="marquee-left text-[#262626] font-black text-6xl md:text-8xl tracking-tighter whitespace-nowrap">
        ZHAOWENHAO // ZHAOWENHAO // ZHAOWENHAO // ZHAOWENHAO // ZHAOWENHAO // ZHAOWENHAO // ZHAOWENHAO // ZHAOWENHAO //
      </div>
      <div class="marquee-right text-[#262626] font-black text-6xl md:text-8xl tracking-tighter whitespace-nowrap">
        ZHAOWENHAO // ZHAOWENHAO // ZHAOWENHAO // ZHAOWENHAO // ZHAOWENHAO // ZHAOWENHAO // ZHAOWENHAO // ZHAOWENHAO //
      </div>
      <div class="marquee-left text-[#262626] font-black text-6xl md:text-8xl tracking-tighter whitespace-nowrap">
        ZHAOWENHAO // ZHAOWENHAO // ZHAOWENHAO // ZHAOWENHAO // ZHAOWENHAO // ZHAOWENHAO // ZHAOWENHAO // ZHAOWENHAO //
      </div>
      <div class="marquee-right text-[#262626] font-black text-6xl md:text-8xl tracking-tighter whitespace-nowrap">
        ZHAOWENHAO // ZHAOWENHAO // ZHAOWENHAO // ZHAOWENHAO // ZHAOWENHAO // ZHAOWENHAO // ZHAOWENHAO // ZHAOWENHAO //
      </div>
      <div class="marquee-left text-[#262626] font-black text-6xl md:text-8xl tracking-tighter whitespace-nowrap">
        ZHAOWENHAO // ZHAOWENHAO // ZHAOWENHAO // ZHAOWENHAO // ZHAOWENHAO // ZHAOWENHAO // ZHAOWENHAO // ZHAOWENHAO //
      </div>
      <div class="marquee-right text-[#262626] font-black text-6xl md:text-8xl tracking-tighter whitespace-nowrap">
        ZHAOWENHAO // ZHAOWENHAO // ZHAOWENHAO // ZHAOWENHAO // ZHAOWENHAO // ZHAOWENHAO // ZHAOWENHAO // ZHAOWENHAO //
      </div>
      <div class="marquee-left text-[#262626] font-black text-6xl md:text-8xl tracking-tighter whitespace-nowrap">
        ZHAOWENHAO // ZHAOWENHAO // ZHAOWENHAO // ZHAOWENHAO // ZHAOWENHAO // ZHAOWENHAO // ZHAOWENHAO // ZHAOWENHAO //
      </div>
      <div class="marquee-right text-[#262626] font-black text-6xl md:text-8xl tracking-tighter whitespace-nowrap">
        ZHAOWENHAO // ZHAOWENHAO // ZHAOWENHAO // ZHAOWENHAO // ZHAOWENHAO // ZHAOWENHAO // ZHAOWENHAO // ZHAOWENHAO //
      </div>
      <div class="marquee-left text-[#262626] font-black text-6xl md:text-8xl tracking-tighter whitespace-nowrap">
        ZHAOWENHAO // ZHAOWENHAO // ZHAOWENHAO // ZHAOWENHAO // ZHAOWENHAO // ZHAOWENHAO // ZHAOWENHAO // ZHAOWENHAO //
      </div>
    </div>
  </div>

  <canvas id="omni-universe" class="absolute inset-0 block w-full h-full z-10 pointer-events-none"></canvas>

  <div class="absolute inset-0 z-20 pointer-events-none flex flex-col items-center justify-center">
    <div class="hero-title-stack flex flex-col items-center justify-center gap-2 select-none">
      <h1 class="font-bold text-6xl md:text-[9.5rem] tracking-tight leading-none text-[#8EDB35] drop-shadow-[0_0_35px_rgba(142,219,53,0.4)]" style="color: #8EDB35;">MAKE</h1>
      <h1 class="font-bold text-6xl md:text-[9.5rem] tracking-tight leading-none text-[#8EDB35] drop-shadow-[0_0_35px_rgba(142,219,53,0.4)]" style="color: #8EDB35;">SOMETHING</h1>
      <h1 class="font-bold text-6xl md:text-[9.5rem] tracking-tight leading-none text-[#8EDB35] drop-shadow-[0_0_35px_rgba(142,219,53,0.4)]" style="color: #8EDB35;">DIFFERENT<span class="hero-dot">.</span></h1>
    </div>

      <div class="absolute bottom-8 inset-x-0 z-20 px-5 text-center pointer-events-none md:bottom-10">
      <span class="block whitespace-nowrap text-neutral-600 text-[clamp(0.72rem,3.1vw,1.125rem)] md:text-2xl tracking-[0.16em] md:tracking-[0.4em] animate-pulse font-mono">
        [ ⬇ 向下滑动 探索更多 ⬇ ]
      </span>
    </div>
  </div>

  <div id="warp-flash" class="absolute inset-0 bg-[#8EDB35] z-50 opacity-0 pointer-events-none transition-opacity duration-300"></div>
  </section>

  <main class="home-sections">
    <section class="home-section chronology-section" aria-labelledby="creative-chronology-title">
      <div class="chronology-pin">
        <div class="chronology-copy">
          <div class="section-kicker">01 / CREATIVE CHRONOLOGY</div>
          <div class="section-head">
            <h2 id="creative-chronology-title">TIMELINE</h2>
          </div>
          <div class="chronology-progress">
            <span data-timeline-current>00</span>
            <i></i>
            <span>12</span>
          </div>
        </div>

        <div class="chronology-map" aria-label="创作编年时间轴">
          <div class="chronology-world" data-timeline-world>
            <svg class="chronology-svg" viewBox="0 0 1000 2140" preserveAspectRatio="none" aria-hidden="true">
              <path
                class="chronology-path is-ghost"
                d="M 500 -20 L 460 140 L 590 300 L 440 460 L 615 640 L 470 820 L 595 980 L 430 1140 L 610 1300 L 470 1460 L 620 1620 L 450 1780 L 585 1940 L 520 2140"
              />
              <path
                class="chronology-path is-live"
                data-timeline-path
                d="M 500 -20 L 460 140 L 590 300 L 440 460 L 615 640 L 470 820 L 595 980 L 430 1140 L 610 1300 L 470 1460 L 620 1620 L 450 1780 L 585 1940 L 520 2140"
              />
            </svg>
            <span class="timeline-head" data-timeline-head aria-hidden="true"></span>

            <a class="timeline-node node-1" href="/profile" data-timeline-node data-x="460" data-y="140">
              <span>2007.01.06 / LIFE</span>
              <strong>出生</strong>
              <em>故事从这里开始。</em>
            </a>
            <a class="timeline-node node-2 has-media" href="/dual" data-timeline-node data-x="590" data-y="300">
              <span>2020.03 / LIFE</span>
              <strong>萌生艺术与设计的想法</strong>
              <em>第一次认真把未来和创作联系在一起。</em>
              <img class="timeline-node-media" src="https://zhao-portfolio-assets.oss-cn-beijing.aliyuncs.com/images/%E6%88%91%E7%9A%84%E7%AC%AC%E4%B8%80%E5%B9%85%E7%94%B5%E5%AD%90%E7%BB%98%E7%94%BB%E4%BD%9C%E5%93%81.webp" alt="我的第一幅电子绘画作品">
            </a>
            <a class="timeline-node node-3" href="/profile" data-timeline-node data-x="440" data-y="460">
              <span>2021.08 / LIFE</span>
              <strong>正式走上艺术道路</strong>
              <em>与家人协商之后，选择把艺术作为真正要走的方向。</em>
            </a>
            <a class="timeline-node node-4 has-media" href="/dual" data-timeline-node data-x="615" data-y="640">
              <span>2022-2025 / LIFE + WORKS</span>
              <strong>深圳市盐田高级中学美术班</strong>
              <em>初步接触设计，并完成一些早期视觉作品。</em>
              <span class="timeline-media-pair">
                <img class="timeline-node-media" src="https://zhao-portfolio-assets.oss-cn-beijing.aliyuncs.com/images/%E3%80%8A%E4%BA%BA%E7%94%9F%E6%98%AF%E6%97%B7%E9%87%8E%EF%BC%8C%E4%B8%8D%E6%98%AF%E8%BD%A8%E9%81%93%E3%80%8B%E5%B7%A5%E8%89%BA%E6%B5%B7%E6%8A%A5.webp" alt="人生是旷野，不是轨道公益海报">
                <img class="timeline-node-media" src="https://zhao-portfolio-assets.oss-cn-beijing.aliyuncs.com/images/%E3%80%8A%E7%BE%A4%E4%BD%93%E6%80%A7%E5%AD%A4%E7%8B%AC%E3%80%8B%E5%85%AC%E7%9B%8A%E6%B5%B7%E6%8A%A5.webp" alt="群体性孤独公益海报">
              </span>
            </a>
            <a class="timeline-node node-5" href="/profile" data-timeline-node data-x="470" data-y="820">
              <span>2025.09 / LIFE</span>
              <strong>进入北京师范大学珠海校区</strong>
              <em>开始艺术设计学专业的学习。</em>
            </a>
            <a class="timeline-node node-6 has-media" href="/omni#yuan" data-timeline-node data-x="595" data-y="980">
              <span>2025.11 / WORK</span>
              <strong>纪录片《缘》</strong>
              <em>影像练习与叙事氛围的阶段性尝试。</em>
              <img class="timeline-node-media" src="https://zhao-portfolio-assets.oss-cn-beijing.aliyuncs.com/posters/%E7%BC%98%E5%B0%81%E9%9D%A2.png" alt="缘短片封面">
            </a>
            <a class="timeline-node node-7 has-media" href="/project-detail#stare-ewsn" data-timeline-node data-x="430" data-y="1140">
              <span>2025.12 / WORK</span>
              <strong>《starE》/《任尔 EWSN 风？》</strong>
              <em>围绕网络舆论场与磁场隐喻展开的装置艺术。</em>
              <img class="timeline-node-media" src="https://zhao-portfolio-assets.oss-cn-beijing.aliyuncs.com/images/%E8%89%BA%E6%9C%AF%E8%A3%85%E7%BD%AE%E3%80%8AstarE%E3%80%8B-%20P7.webp" alt="starE 装置作品">
            </a>
            <a class="timeline-node node-8 has-media" href="/project-detail#liminal" data-timeline-node data-x="610" data-y="1300">
              <span>2026.01 / WORK</span>
              <strong>《Liminal-临近边缘的幻想》</strong>
              <em>关于算法、虚构与真实边界的实验短片。</em>
              <img class="timeline-node-media" src="https://zhao-portfolio-assets.oss-cn-beijing.aliyuncs.com/posters/Liminal%E5%B0%81%E9%9D%A2.png" alt="Liminal 短片封面">
            </a>
            <a class="timeline-node node-9 has-media" href="/project-detail#never-extinguished" data-timeline-node data-x="470" data-y="1460">
              <span>2026.01 / WORK</span>
              <strong>VR 游戏《Never Extinguished》</strong>
              <em>以东北下岗潮为背景的 VR 严肃游戏原型。</em>
              <img class="timeline-node-media" src="https://zhao-portfolio-assets.oss-cn-beijing.aliyuncs.com/images/VR%E4%B8%A5%E8%82%83%E6%B8%B8%E6%88%8F%E3%80%8A%E6%9C%AA%E6%9B%BE%E7%86%84%E7%81%AD%E7%9A%84%E3%80%8B%E5%AE%A3%E4%BC%A0%E6%B5%B7%E6%8A%A5%20%E6%8B%B7%E8%B4%9D.webp" alt="Never Extinguished 宣传海报">
            </a>
            <a class="timeline-node node-10 has-media" href="/project-detail#nazhou-ar" data-timeline-node data-x="620" data-y="1620">
              <span>2026.04 / WORK</span>
              <strong>AR 游戏 Demo《画意那洲·文化寻根》</strong>
              <em>把景区导览转化为带有探索循环的 AR 体验。</em>
              <img class="timeline-node-media" src="https://zhao-portfolio-assets.oss-cn-beijing.aliyuncs.com/posters/%E9%82%A3%E6%B4%B2%E6%9D%91AR%E5%AF%BC%E8%A7%88DEMO%E6%BC%94%E7%A4%BA%E8%A7%86%E9%A2%91%E5%B0%81%E9%9D%A2.png" alt="画意那洲 AR 导览 Demo 封面">
            </a>
            <a class="timeline-node node-11 has-media" href="/project-detail#miao-generator" data-timeline-node data-x="450" data-y="1780">
              <span>2026.06 / WORK</span>
              <strong>交互网页《施洞苗绣纹样生成器》</strong>
              <em>以非遗纹样为素材的数字共创与交互生成实验。</em>
              <img class="timeline-node-media" src="https://zhao-portfolio-assets.oss-cn-beijing.aliyuncs.com/images/%E6%96%BD%E6%B4%9E%E8%8B%97%E7%BB%A31.webp" alt="施洞苗绣纹样生成器界面">
            </a>
            <a class="timeline-node node-12 has-media" href="/project-detail#shadow-shell" data-timeline-node data-x="585" data-y="1940">
              <span>2026.06 / WORK</span>
              <strong>建筑设计《Shadow Shell》</strong>
              <em>围绕光影、遮蔽与临时结构展开的建筑模型实验。</em>
              <img class="timeline-node-media" src="https://zhao-portfolio-assets.oss-cn-beijing.aliyuncs.com/images/Shadow%20Shell%201.webp" alt="Shadow Shell 建筑模型">
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="home-section works-section" aria-labelledby="home-works-title">
      <div class="works-pin">
        <div class="works-control">
          <h2 id="home-works-title"><span aria-hidden="true"></span>WORKS CATEGORY</h2>
          <div class="works-category-list" aria-label="作品分类">
            <button class="works-category is-active" type="button" data-work-category="digital">
              <span>1:</span> 数字艺术
            </button>
            <button class="works-category" type="button" data-work-category="film">
              <span>2:</span> 短片
            </button>
            <button class="works-category" type="button" data-work-category="photo">
              <span>3:</span> 摄影作品
            </button>
            <button class="works-category" type="button" data-work-category="other">
              <span>4:</span> 其他
            </button>
          </div>
          <div class="works-progress" aria-live="polite">
            <span data-work-current>01</span>
            <i></i>
            <span data-work-total>10</span>
          </div>
        </div>

        <div class="works-stage" aria-label="首页作品预览叠层">
          <article class="works-layer is-active" data-work-card data-work-category="digital" data-work-kind="image">
            <img src="https://zhao-portfolio-assets.oss-cn-beijing.aliyuncs.com/images/VR%E4%B8%A5%E8%82%83%E6%B8%B8%E6%88%8F%E3%80%8A%E6%9C%AA%E6%9B%BE%E7%86%84%E7%81%AD%E7%9A%84%E3%80%8B%E5%AE%A3%E4%BC%A0%E6%B5%B7%E6%8A%A5%20%E6%8B%B7%E8%B4%9D.webp" alt="未曾熄灭的作品海报">
            <div class="works-layer-copy">
              <span>VR 严肃游戏 / 2026</span>
              <h3>未曾熄灭的</h3>
              <p>以 90 年代末东北车间为沉浸式场景，把历史创伤、怀旧疗法和自然交互整合进一套可体验的游戏叙事。</p>
              <a href="/project-detail#never-extinguished">查看项目</a>
            </div>
          </article>

          <article class="works-layer" data-work-card data-work-category="digital" data-work-kind="image">
            <img src="https://zhao-portfolio-assets.oss-cn-beijing.aliyuncs.com/posters/%E9%82%A3%E6%B4%B2%E6%9D%91AR%E5%AF%BC%E8%A7%88DEMO%E6%BC%94%E7%A4%BA%E8%A7%86%E9%A2%91%E5%B0%81%E9%9D%A2.png" alt="那洲村 AR 导览游戏 Demo">
            <div class="works-layer-copy">
              <span>AR 导览游戏 / 2026</span>
              <h3>画意那洲·文化寻根</h3>
              <p>把景区导览转译为收集碎片的探索循环，让游客在移动和寻找中进入地方文化叙事。</p>
              <a href="/project-detail#nazhou-ar">查看项目</a>
            </div>
          </article>

          <article class="works-layer" data-work-card data-work-category="digital" data-work-kind="image">
            <img src="https://zhao-portfolio-assets.oss-cn-beijing.aliyuncs.com/images/%E6%96%BD%E6%B4%9E%E8%8B%97%E7%BB%A31.webp" alt="施洞苗绣纹样生成器界面">
            <div class="works-layer-copy">
              <span>交互网页 / 2026</span>
              <h3>施洞苗绣纹样生成器</h3>
              <p>围绕施洞苗绣传统图腾展开的数字共创网页，用户可以组合纹样、调节构图与色板，并获得 AI 纹样评审反馈。</p>
              <a href="/project-detail#miao-generator">查看项目</a>
            </div>
          </article>

          <article class="works-layer" data-work-card data-work-category="digital" data-work-kind="image">
            <img src="https://zhao-portfolio-assets.oss-cn-beijing.aliyuncs.com/images/%E8%89%BA%E6%9C%AF%E8%A3%85%E7%BD%AE%E3%80%8AstarE%E3%80%8B-%20P7.webp" alt="starE 装置作品">
            <div class="works-layer-copy">
              <span>装置艺术 / 2025</span>
              <h3>starE / 任尔 EWSN 风？</h3>
              <p>以磁场隐喻网络舆论场，把抽象的公共讨论结构转化为可被观看和感知的实体装置。</p>
              <a href="/project-detail#stare-ewsn">查看项目</a>
            </div>
          </article>

          <article class="works-layer is-video" data-work-card data-work-category="film" data-work-kind="video">
            <img src="https://zhao-portfolio-assets.oss-cn-beijing.aliyuncs.com/posters/Liminal%E5%B0%81%E9%9D%A2.png" alt="Liminal 短片封面">
            <video src="https://zhao-portfolio-assets.oss-cn-beijing.aliyuncs.com/videos/Liminal-%E4%B8%B4%E8%BF%91%E8%BE%B9%E7%BC%98%E7%9A%84%E5%B9%BB%E6%83%B3.mp4" preload="metadata" muted playsinline></video>
            <button class="works-play" type="button" aria-label="播放 Liminal">CLICK TO PLAY</button>
            <div class="works-layer-copy">
              <span>实验短片 / 2026</span>
              <h3>Liminal 临近边缘的幻想</h3>
              <p>围绕算法、虚构和真实边界展开的影像实验，讨论当代视觉经验中不断增殖的“非真实”。</p>
              <a href="/project-detail#liminal">查看项目</a>
            </div>
          </article>

          <article class="works-layer is-video" data-work-card data-work-category="film" data-work-kind="video">
            <img src="https://zhao-portfolio-assets.oss-cn-beijing.aliyuncs.com/posters/%E7%BC%98%E5%B0%81%E9%9D%A2.png" alt="缘 短片封面">
            <video src="https://zhao-portfolio-assets.oss-cn-beijing.aliyuncs.com/videos/%E7%BC%98.mp4" preload="metadata" muted playsinline></video>
            <button class="works-play" type="button" aria-label="播放缘">CLICK TO PLAY</button>
            <div class="works-layer-copy">
              <span>影像练习</span>
              <h3>缘</h3>
              <p>从片段、节奏和情绪出发的短片作品，作为影像语言与叙事氛围的阶段性练习。</p>
              <a href="/omni#yuan">进入视频页</a>
