      --works-count: 10;
      --works-intro-hold: 125vh;
      --works-step-scroll: 96vh;
      --work-step-progress: 0;
      min-height: calc(100vh + var(--works-intro-hold) + (var(--works-count) - 1) * var(--works-step-scroll));
      margin-left: 0;
      margin-right: 0;
      padding-bottom: 0;
      padding-top: 0;
      position: relative;
      width: 100%;
    }

    .works-section::before {
      background:
        linear-gradient(90deg, rgba(142, 219, 53, 0.1) 1px, transparent 1px),
        linear-gradient(180deg, rgba(255, 255, 255, 0.045) 1px, transparent 1px);
      background-size: 72px 72px;
      content: "";
      inset: clamp(3rem, 6vw, 5rem) 0;
      opacity: 0.22;
      pointer-events: none;
      position: absolute;
      transform: skewY(-3deg);
    }

    .works-pin {
      box-sizing: border-box;
      height: 100vh;
      min-height: 100vh;
      position: sticky;
      top: 0;
      z-index: 1;
    }

    .works-control {
      display: grid;
      gap: clamp(1rem, 2vh, 1.45rem);
      justify-items: start;
      left: clamp(2rem, 4vw, 4.6rem);
      max-width: min(23rem, 32vw);
      position: absolute;
      top: clamp(6rem, 11vh, 8rem);
      z-index: 6;
    }

    .works-control h2 {
      align-items: center;
      color: rgba(245, 245, 245, 0.92);
      display: flex;
      gap: 0.78rem;
      font-family: var(--font-mono-cn);
      font-size: clamp(1.05rem, 1.55vw, 1.52rem);
      font-weight: 700;
      letter-spacing: 0.08em;
      line-height: 1;
      margin: 0;
      text-shadow:
        -1px 0 #ff3048,
        1px 0 #00f0ff,
        0 0 18px rgba(0, 0, 0, 0.72);
      white-space: nowrap;
    }

    .works-control h2 span {
      background: rgba(245, 245, 245, 0.92);
      border: 1px solid rgba(142, 219, 53, 0.72);
      border-radius: 999px;
      box-shadow:
        -1px 0 #ff3048,
        1px 0 #00f0ff,
        0 0 12px rgba(142, 219, 53, 0.24);
      display: block;
      height: 1.05rem;
      width: 1.35rem;
    }

    .works-category-list {
      display: grid;
      gap: clamp(0.72rem, 1.45vh, 1.05rem);
      margin-top: 0;
    }

    .works-category {
      appearance: none;
      background: transparent;
      border: 0;
      color: rgba(245, 245, 245, 0.56);
      font-family: var(--font-mono-cn);
      font-size: clamp(0.92rem, 1.25vw, 1.12rem);
      font-weight: 700;
      letter-spacing: 0.03em;
      padding: 0.12rem 0;
      text-align: left;
      text-shadow:
        -1px 0 rgba(255, 48, 72, 0.62),
        1px 0 rgba(0, 240, 255, 0.62);
      transition: color 180ms ease;
    }

    .works-category span {
      color: rgba(142, 219, 53, 0.66);
      display: inline-block;
      min-width: 1.6rem;
    }

    .works-category.is-active {
      color: #8EDB35;
      text-shadow: 0 0 14px rgba(142, 219, 53, 0.42);
    }

    .works-category.is-empty {
      color: rgba(245, 245, 245, 0.28);
      opacity: 0.58;
    }

    .works-category.is-empty span {
      color: rgba(142, 219, 53, 0.34);
    }

    .works-progress {
      align-items: center;
      color: rgba(245, 245, 245, 0.62);
      display: flex;
      font-family: var(--font-mono-cn);
      font-size: 0.74rem;
      gap: 0.65rem;
      letter-spacing: 0.16em;
      margin-top: 0.5rem;
      text-shadow: 0 0 14px rgba(0, 0, 0, 0.8);
    }

    .works-progress i {
      background: rgba(245, 245, 245, 0.22);
      display: block;
      height: 1px;
      overflow: hidden;
      position: relative;
      width: 3.5rem;
    }

    .works-progress i::after {
      background: #8EDB35;
      box-shadow: 0 0 12px rgba(142, 219, 53, 0.62);
      content: "";
      inset: 0;
      position: absolute;
      transform: scaleX(var(--work-step-progress));
      transform-origin: left center;
      transition: transform 120ms linear;
    }

    .works-stage {
      inset: clamp(4.7rem, 8vh, 6.25rem) clamp(1.7rem, 3vw, 3.4rem) clamp(1.4rem, 3.5vh, 2.4rem);
      min-height: 0;
      position: absolute;
      z-index: 1;
    }

    .works-layer {
      --offset: 0;
      --abs-offset: 0;
      --stack-order: 1;
      background: #050505;
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 22px;
      box-shadow: 0 34px 110px rgba(0, 0, 0, 0.58);
      color: #ffffff;
      height: 100%;
      left: 50%;
      min-height: 0;
      overflow: hidden;
      position: absolute;
      top: 50%;
      transform:
        translate(
          calc(-50% + var(--offset) * -32px),
          calc(-50% + var(--offset) * 22px)
        )
        rotate(calc(var(--offset) * -0.42deg))
        scale(calc(1 - var(--depth) * 0.018));
      transform-origin: 62% 54%;
      opacity: 0;
      transition: filter 180ms ease, opacity 180ms ease;
      visibility: hidden;
      will-change: transform, opacity;
      width: 100%;
      z-index: var(--stack-order);
    }

    .works-layer.is-past {
      pointer-events: none;
    }

    .works-layer.is-active {
      cursor: pointer;
    }

    .works-layer.is-active::after {
      z-index: 2;
    }

    .works-layer.is-active .works-layer-copy::after {
      background: rgba(245, 245, 245, 0.2);
      content: "";
      height: 2px;
      left: 0;
      position: absolute;
      top: -1rem;
      width: min(15rem, 42vw);
    }

    .works-layer.is-active .works-layer-copy::before {
      background: #8EDB35;
      box-shadow: 0 0 14px rgba(142, 219, 53, 0.7);
      content: "";
      height: 2px;
      left: 0;
      position: absolute;
      top: -1rem;
      transform: scaleX(var(--work-step-progress));
      transform-origin: left center;
      transition: transform 120ms linear;
      width: min(15rem, 42vw);
      z-index: 1;
    }

    .works-layer img,
    .works-layer video {
      display: block;
      filter: grayscale(0.45) contrast(1.08);
      height: 100%;
      inset: 0;
      object-fit: cover;
      position: absolute;
      top: 0;
      transform: translateZ(0) scale(1.006);
      transition: filter 260ms ease, opacity 220ms ease, transform 520ms cubic-bezier(0.16, 1, 0.3, 1);
      will-change: filter, transform, opacity;
      width: 100%;
    }

    .works-layer video {
      opacity: 0;
      z-index: 1;
    }

    :global(.works-layer.is-playing video) {
      opacity: 1 !important;
    }

    :global(.works-layer.is-playing img) {
      opacity: 0 !important;
    }

    .works-layer.is-active img {
      animation: worksMediaEnter 520ms cubic-bezier(0.16, 1, 0.3, 1);
      filter: grayscale(0.2) contrast(1.12);
      transform: translateZ(0) scale(1);
    }

    .works-layer::after {
      background:
        linear-gradient(180deg, rgba(0, 0, 0, 0.04) 0%, rgba(0, 0, 0, 0.8) 82%),
        linear-gradient(90deg, rgba(0, 0, 0, 0.68) 0%, rgba(0, 0, 0, 0.28) 36%, transparent 70%);
      content: "";
      inset: 0;
      pointer-events: none;
      position: absolute;
      z-index: 2;
    }

    .works-play {
      appearance: none;
      background: rgba(5, 5, 5, 0.78);
      border: 1px solid rgba(142, 219, 53, 0.54);
      border-radius: 999px;
      bottom: clamp(1.25rem, 3vh, 2rem);
      color: #8EDB35;
      font-family: var(--font-mono-cn);
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.14em;
      padding: 0.55rem 0.8rem;
      position: absolute;
      right: clamp(1.25rem, 4vw, 4.5rem);
      z-index: 4;
    }

    .works-layer.is-playing .works-play {
      bottom: auto;
      color: rgba(245, 245, 245, 0.72);
      opacity: 0.72;
      padding: 0.42rem 0.62rem;
      right: clamp(1rem, 2vw, 1.6rem);
      top: clamp(1rem, 2vw, 1.6rem);
    }

    .works-layer.is-playing .works-play::before {
      content: "PLAYING / ";
    }

    .works-layer-copy {
      bottom: clamp(1.25rem, 3vh, 2.25rem);
      display: grid;
      gap: 0.58rem;
      left: clamp(1.25rem, 4vw, 4.5rem);
      max-width: min(78rem, calc(100vw - clamp(2.5rem, 8vw, 9rem)));
      position: absolute;
      right: clamp(1.25rem, 4vw, 4.5rem);
      z-index: 3;
    }

    .works-layer.is-active .works-layer-copy {
      animation: worksCopyEnter 420ms cubic-bezier(0.16, 1, 0.3, 1);
    }

    .is-video .works-layer-copy {
      padding-left: 0;
    }

    .works-layer-copy span {
      color: #8EDB35;
      font-family: var(--font-mono-cn);
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.12em;
    }

    .works-layer-copy h3 {
      color: #ffffff;
      font-size: clamp(1.85rem, min(3.85vw, 7.4vh), 4.35rem);
      font-weight: 600;
      letter-spacing: 0;
      line-height: 0.96;
      margin: 0;
      max-width: 100%;
      white-space: nowrap;
    }

    .works-title-split {
      align-items: baseline;
      display: flex;
      flex-wrap: nowrap;
      gap: 0.32em;
    }

    .works-title-split .works-title-cn,
    .works-title-split .works-title-en {
      display: block;
      font-family: inherit;
      letter-spacing: 0;
    }

    .works-title-split .works-title-cn {
      color: #ffffff;
      font-size: 1em;
      font-weight: 600;
      line-height: 0.96;
    }

    .works-title-split .works-title-en {
      color: rgba(255, 255, 255, 0.84);
      font-size: 0.58em;
      font-weight: 500;
      line-height: 1;
      white-space: nowrap;
    }

    .works-layer-copy p {
      color: rgba(245, 245, 245, 0.72);
      font-size: clamp(0.92rem, 1.15vw, 1.08rem);
      line-height: 1.72;
      margin: 0;
      max-width: 42rem;
    }

    .works-layer-copy a {
      color: rgba(142, 219, 53, 0.9);
      font-family: var(--font-mono-cn);
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      margin-top: 0.25rem;
      text-decoration: none;
      width: fit-content;
    }

    .profile-section {
      overflow: hidden;
      position: relative;
      width: min(1360px, calc(100vw - 32px));
    }

    .profile-section::before {
      background:
        linear-gradient(90deg, rgba(142, 219, 53, 0.12) 1px, transparent 1px),
        linear-gradient(180deg, rgba(255, 255, 255, 0.06) 1px, transparent 1px);
      background-size: 84px 84px;
      content: "";
      inset: 0;
      opacity: 0.22;
      pointer-events: none;
      position: absolute;
      transform: skewY(-4deg);
    }

    .profile-layout {
      align-items: stretch;
      display: grid;
      gap: clamp(2rem, 5vw, 5rem);
      grid-template-columns: minmax(0, 1fr) minmax(320px, 0.78fr);
      min-height: clamp(31rem, 46vw, 39rem);
      position: relative;
      z-index: 1;
    }

    .profile-copy {
      border-bottom: 1px solid rgba(255, 255, 255, 0.12);
      border-top: 1px solid rgba(255, 255, 255, 0.12);
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      max-width: none;
      min-height: 100%;
      padding: clamp(1.4rem, 3vw, 2.25rem) 0;
    }

    .profile-copy-main {
      display: grid;
      gap: clamp(0.9rem, 1.8vw, 1.35rem);
      justify-items: start;
      max-width: min(100%, 50rem);
      width: 100%;
    }

    .profile-heading {
      align-items: end;
      display: flex;
      gap: 1.2rem;
      justify-content: flex-start;
      width: 100%;
    }

    .profile-copy h2 {
      align-items: end;
      color: #ffffff;
      display: inline-flex;
      font-size: clamp(2.35rem, 5.4vw, 5.2rem);
      font-weight: 600;
      gap: 0.32em;
      letter-spacing: 0;
      line-height: 0.95;
      margin: 0;
    }

    .profile-copy h2::after {
      animation: profileCursorBlink 1s steps(2, start) infinite;
      background: #8EDB35;
      box-shadow: 0 0 16px rgba(142, 219, 53, 0.8);
      content: "";
      display: inline-block;
      height: 0.12em;
      margin-bottom: 0.1em;
      width: 0.72em;
    }

    .profile-lead {
      color: #ffffff !important;
      font-size: clamp(1.02rem, 1.5vw, 1.2rem) !important;
      font-weight: 500;
      line-height: 1.72 !important;
    }

    .profile-brief-list {
      border-block: 1px solid rgba(255, 255, 255, 0.1);
      display: grid;
      gap: 0;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      margin-top: clamp(0.6rem, 1.5vw, 1.2rem);
      width: min(100%, 50rem);
    }

    .profile-brief-list span {
      color: #8EDB35;
      font-family: var(--font-mono-cn);
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      padding: 0.85rem 1rem 0.85rem 0;
    }

    .profile-brief-list span + span {
      border-left: 1px solid rgba(255, 255, 255, 0.1);
      padding-left: 1rem;
    }

    .profile-detail-grid {
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
      display: grid;
      gap: 0;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      margin-top: clamp(0.15rem, 0.8vw, 0.65rem);
      width: min(100%, 50rem);
    }

    .profile-detail-grid div {
      display: grid;
      gap: 0.35rem;
      min-height: 5.4rem;
      padding: 1rem 1.2rem 1.1rem 0;
    }

    .profile-detail-grid div + div {
      border-left: 1px solid rgba(255, 255, 255, 0.1);
      padding-left: 1.2rem;
    }

    .profile-detail-grid span {
      color: #8EDB35;
      font-family: var(--font-mono-cn);
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.16em;
    }

    .profile-detail-grid p {
      align-self: end;
      color: rgba(245, 245, 245, 0.78);
      font-size: clamp(0.88rem, 1.05vw, 1rem);
      line-height: 1.55;
      margin: 0;
    }

    .profile-mini {
      display: grid;
      gap: 0;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      margin-top: clamp(2.2rem, 5vw, 4rem);
      width: min(100%, 50rem);
    }

    .profile-mini div {
      border-top: 1px solid rgba(255, 255, 255, 0.1);
      display: grid;
      gap: 0.35rem;
      min-height: 4.8rem;
      padding-top: 1rem;
    }

    .profile-mini div + div {
      border-left: 1px solid rgba(255, 255, 255, 0.1);
      padding-left: 1.4rem;
    }

    .profile-mini span {
      color: #8EDB35;
      font-family: var(--font-mono-cn);
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.16em;
    }

    .profile-mini strong {
      color: rgba(245, 245, 245, 0.86);
      font-size: clamp(0.92rem, 1.1vw, 1.02rem);
      font-weight: 500;
      line-height: 1.55;
    }

    .profile-mini-link {
      align-self: end;
      color: #8EDB35;
      font-family: var(--font-mono-cn);
      font-size: clamp(0.78rem, 0.95vw, 0.9rem);
      font-weight: 700;
      letter-spacing: 0.12em;
      line-height: 1.55;
      text-decoration: none;
      width: fit-content;
    }

    .profile-visual {
      min-height: 100%;
      position: relative;
    }

    .profile-model-panel {
      background:
        radial-gradient(circle at 50% 45%, rgba(142, 219, 53, 0.12), transparent 34%),
        linear-gradient(90deg, rgba(142, 219, 53, 0.08) 1px, transparent 1px),
        linear-gradient(180deg, rgba(255, 255, 255, 0.05) 1px, transparent 1px),
        rgba(5, 5, 5, 0.28);
      background-size: auto, 62px 62px, 62px 62px, auto;
      border: 1px solid rgba(142, 219, 53, 0.24);
      border-radius: 16px;
      height: 100%;
      min-height: 100%;
      overflow: hidden;
      position: relative;
    }

    .profile-model-panel::after {
      border: 1px solid rgba(255, 255, 255, 0.05);
      border-radius: inherit;
      content: "";
      inset: 0.65rem;
      pointer-events: none;
      position: absolute;
    }

    .profile-model-panel canvas {
      display: block;
      height: 100%;
      min-height: 100%;
      width: 100%;
    }

    @keyframes profileCursorBlink {
      0%, 48% { opacity: 1; }
      49%, 100% { opacity: 0; }
    }

    @keyframes worksMediaEnter {
      0% {
        filter: grayscale(0.52) contrast(1.02);
        transform: translateZ(0) scale(1.024);
      }

      100% {
        filter: grayscale(0.2) contrast(1.12);
        transform: translateZ(0) scale(1);
      }
    }

    @keyframes worksCopyEnter {
      0% {
        opacity: 0;
        transform: translate3d(0, 0.65rem, 0);
      }

      100% {
        opacity: 1;
        transform: translate3d(0, 0, 0);
      }
    }

    @keyframes moveLeft { 0% { transform: translateX(0%); } 100% { transform: translateX(-25%); } }
    @keyframes moveRight { 0% { transform: translateX(-25%); } 100% { transform: translateX(0%); } }
    .marquee-left { display: inline-block; animation: moveLeft 12s linear infinite; }
    .marquee-right { display: inline-block; animation: moveRight 12s linear infinite; }

    @media (max-width: 900px) {
      .home-sections {
        overflow-x: clip;
        overflow-y: visible;
      }

      .home-section {
        width: min(1180px, calc(100vw - 1.25rem));
      }

      .section-kicker {
        font-size: 0.66rem;
        letter-spacing: 0.18em;
        margin-bottom: 0.65rem;
      }

      .section-head h2,
      .chronology-copy h2 {
        font-size: clamp(2.6rem, 15vw, 4.3rem);
        line-height: 0.94;
      }

      .split-head,
      .profile-layout {
        grid-template-columns: 1fr;
      }

      .chronology-section {
        --timeline-camera-scale: 1.02;
        --timeline-progress: 0;
        border-top: 0;
        margin-left: 0;
        margin-right: 0;
        min-height: var(--timeline-section-height, 760vh);
        padding: 0;
        width: 100%;
      }

      .chronology-pin {
        box-sizing: border-box;
        height: 100vh;
        height: 100svh;
        height: var(--stable-app-height, 100svh);
        min-height: 100vh;
        min-height: 100svh;
        min-height: var(--stable-app-height, 100svh);
        overflow: hidden;
        padding: calc(env(safe-area-inset-top) + 4.45rem) 0.7rem 0.85rem;
        position: sticky;
        top: 0;
      }

      .chronology-copy {
        left: 0.95rem;
        max-width: min(23rem, calc(100vw - 1.9rem));
        position: absolute;
        top: calc(env(safe-area-inset-top) + 4.65rem);
        z-index: 4;
      }

      .chronology-copy .section-head {
        gap: 0.78rem;
        margin-bottom: 0.8rem;
      }

      .chronology-copy h2 {
        font-size: clamp(2.85rem, 16vw, 4.4rem);
        line-height: 0.9;
      }

      .chronology-progress {
        font-size: 0.7rem;
        gap: 0.6rem;
        margin-top: 0.75rem;
      }

      .chronology-progress i {
        width: 4.1rem;
      }

      .chronology-map {
        inset: calc(env(safe-area-inset-top) + 12.4rem) 0.65rem 0.82rem;
        margin-top: 0;
        min-height: 0;
        overflow: hidden;
        position: absolute;
      }

      .chronology-map::before {
        background-size: 40px 40px, 40px 40px;
        display: block;
        inset: -18%;
        opacity: 0.68;
      }

      .chronology-map::after {
        display: block;
      }

      .chronology-world {
        display: block;
        height: 2140px;
        left: 0;
        padding: 0;
        position: absolute;
        top: 0;
        transform: translate3d(var(--timeline-camera-x), var(--timeline-camera-y), 0) scale(var(--timeline-camera-scale)) !important;
        transform-origin: 0 0;
        width: 1000px;
      }

      .chronology-world::before {
        display: none;
      }

      .chronology-svg {
        display: block;
      }

      .timeline-head {
        display: block;
        height: 0.62rem;
        width: 0.62rem;
      }

      .timeline-node,
      .timeline-node.is-active,
      .timeline-node.is-current {
        border-radius: 12px;
        display: grid;
        gap: 0.32rem;
        left: var(--node-x);
        max-width: min(17.5rem, 74vw);
        min-width: 0;
        padding: 0;
        position: absolute;
        top: var(--node-y);
        width: 0;
      }

      .timeline-node {
        opacity: 0;
        pointer-events: none;
        transform: translate(-50%, -50%) scale(0.82);
      }

      .timeline-node.is-active {
        background: transparent;
        border-color: transparent;
        box-shadow: none;
        opacity: 1;
        pointer-events: none;
        transform: translate(-50%, -50%) scale(1);
      }

      .timeline-node.is-current {
        background: rgba(10, 14, 8, 0.93);
        border: 1px solid rgba(142, 219, 53, 0.62);
        box-shadow: 0 14px 42px rgba(0, 0, 0, 0.48);
        opacity: 1;
        padding: 0.76rem 0.82rem 0.82rem;
        pointer-events: auto;
        transform: translate(-50%, -50%) scale(1);
        width: min(17.5rem, 74vw);
        z-index: 6;
      }

      .timeline-node::before {
        background: #8EDB35;
        box-shadow: 0 0 14px rgba(142, 219, 53, 0.72);
        display: block;
        height: 0.52rem;
        left: 50%;
        opacity: 1;
        top: 50%;
        transform: translate(-50%, -50%);
        width: 0.52rem;
      }

      .timeline-node.is-current::before,
      .timeline-node[data-card-side="right"].is-current::before {
