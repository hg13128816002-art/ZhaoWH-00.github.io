  <script>
    // ================= 终极全域 Canvas 粒子引擎 =================
    const canvas = document.getElementById('omni-universe') as HTMLCanvasElement;
    const ctx = canvas.getContext('2d')!;

    let width = window.innerWidth;
    let height = window.innerHeight;
    const mobileMotionQuery = window.matchMedia('(max-width: 899px)');
    function resize() {
      width = window.innerWidth; height = window.innerHeight;
      canvas.width = width; canvas.height = height;
      if (mobileMotionQuery.matches) {
        ctx.clearRect(0, 0, width, height);
        canvas.style.visibility = 'hidden';
      }
    }
    window.addEventListener('resize', resize);
    resize();
    // 默认隐藏 canvas，待字体加载完毕再显示并开始渲染，避免回退字体被绘制到画布上
    canvas.style.visibility = 'hidden';

    let mouseX = width / 2;
    let mouseY = height / 2;
    let cursorX = mouseX;
    let cursorY = mouseY;

    if (window.matchMedia('(pointer: fine)').matches) {
      window.addEventListener('pointermove', (event) => {
        mouseX = event.clientX;
        mouseY = event.clientY;
      }, { passive: true });
    }

    // 信仰链目标定义 (尾部加入适量空格完美分布圆周)
    const creedString = "INTEGRATE THINKING INTO DESIGN • ";
    const targetLength = creedString.length;

    interface OmniParticle {
      x: number; y: number;
      baseX: number; baseY: number;
      originalChar: string;
      currentChar: string;
      size: number;
      angle: number; speed: number;
      clusterIndex: number;
      type: 'core' | 'ring';
      
      orbitR?: number;
      ringRX?: number; ringRY?: number; ringTilt?: number;
      
      // ！！！终极单层与指心控制属性 ！！！
      targetCursorSlot: number; // 预分配在信条环上的专属独立槽位 (0 - 32)
      isRingAssigned: boolean;  // 核心标记：该粒子是否被选中组成那绝对唯一的“单层光环”
      isCaptured: boolean;
    }

    const baseChars = ['设', '计', '思', '维', '先', '锋', '0', '1', '+', '#', '×', '•'];
    const particles: OmniParticle[] = [];
    
    // ！！！极其核心修复：精准映射手绘图的三体布局与大小节奏 ！！！
    const planets = [
      // 01. 红色区域：超巨型主星 (左上至中左)。极大画幅，拥有辽阔顺时针星环，长轴略微右偏。
      { cx: width * 0.28, cy: height * 0.45, coreR: 176, ringRX: 418, ringRY: 132, tilt: 0.35, orbitRotation: Math.PI / 12, dir: 1, pCore: 220, pRing: 260, baseSize: 16 },
      // 02. 黄色区域：中型伴星 (右下偏中)。适中画幅，逆时针偏转大星环，长轴左倾。
      { cx: width * 0.78, cy: height * 0.75, coreR: 90, ringRX: 240, ringRY: 75, tilt: -0.4, orbitRotation: -Math.PI / 6, dir: -1, pCore: 120, pRing: 150, baseSize: 13 },
      // 03. 蓝色区域：微型远星 (右上深空)。极其精致紧凑，点缀深空景深。
      { cx: width * 0.82, cy: height * 0.22, coreR: 50, ringRX: 140, ringRY: 40, tilt: 0.2, orbitRotation: Math.PI / 8, dir: 1, pCore: 70, pRing: 90, baseSize: 10 }
    ];

    // 全量安全天体灌注 (修复底层死锁)
    planets.forEach((p, pIdx) => {
      // 灌注自转内核
      for (let i = 0; i < p.pCore; i++) {
        // 确保每个星球平均只有前 targetLength 个粒子被标记为“单层组成者”，多余的仅作普通飞溅物
        const slot = i % targetLength;
        const isAssigned = i < targetLength; 
        particles.push({
          x: 0, y: 0, baseX: 0, baseY: 0,
          originalChar: baseChars[Math.floor(Math.random() * baseChars.length)],
          currentChar: '', size: Math.random() * 6 + p.baseSize,
          angle: Math.random() * Math.PI * 2, speed: (Math.random() * 0.004 + 0.002) * p.dir,
          clusterIndex: pIdx, type: 'core', orbitR: Math.sqrt(Math.random()) * p.coreR,
          targetCursorSlot: slot, isRingAssigned: isAssigned, isCaptured: false
        });
      }
      // 灌注宏大星环
      for (let i = 0; i < p.pRing; i++) {
        const slot = i % targetLength;
        // 让星环也贡献一层备用骨架，确保视觉极其丰满但绝不重叠乱码
        const isAssigned = i < targetLength; 
        particles.push({
          x: 0, y: 0, baseX: 0, baseY: 0,
          originalChar: baseChars[Math.floor(Math.random() * baseChars.length)],
          currentChar: '', size: Math.random() * 4 + p.baseSize * 0.8,
          angle: (i / p.pRing) * Math.PI * 2, speed: (0.0015 + Math.random() * 0.0015) * p.dir,
          clusterIndex: pIdx, type: 'ring', 
          ringRX: p.ringRX * (0.82 + Math.random() * 0.36), ringRY: p.ringRY * (0.82 + Math.random() * 0.36),
          ringTilt: p.tilt,
          targetCursorSlot: slot, isRingAssigned: isAssigned, isCaptured: false
        });
      }
    });

    let cursorSpinAngle = 0;

    function renderUniverse() {
      if (mobileMotionQuery.matches) {
        ctx.clearRect(0, 0, width, height);
        canvas.style.visibility = 'hidden';
        return;
      }

      ctx.clearRect(0, 0, width, height);

      // 光标物理缓动更新
      cursorX += (mouseX - cursorX) * 0.15;
      cursorY += (mouseY - cursorY) * 0.15;
      
      // 光标环自转极速驱动
      cursorSpinAngle += 0.015;

      // 实时计算三体核心响应视口变化
      planets[0].cx = width * 0.28; planets[0].cy = height * 0.45;
      planets[1].cx = width * 0.78; planets[1].cy = height * 0.75;
      planets[2].cx = width * 0.82; planets[2].cy = height * 0.22;

      particles.forEach(n => {
        const p = planets[n.clusterIndex];

        // --- 独立天体矩阵轨道演算 ---
        n.angle += n.speed;
        let localX = 0; let localY = 0;

        if (n.type === 'core') {
          localX = Math.cos(n.angle) * n.orbitR!;
          localY = Math.sin(n.angle) * n.orbitR!;
        } else {
          const ux = Math.cos(n.angle) * n.ringRX!;
          const uy = Math.sin(n.angle) * n.ringRY!;
          localX = ux * Math.cos(n.ringTilt!) - uy * Math.sin(n.ringTilt!);
          localY = ux * Math.sin(n.ringTilt!) + uy * Math.cos(n.ringTilt!);
        }

        // 叠加天体偏转角形成彻底独立的朝向错落感
        n.baseX = p.cx + (localX * Math.cos(p.orbitRotation) - localY * Math.sin(p.orbitRotation));
        n.baseY = p.cy + (localX * Math.sin(p.orbitRotation) + localY * Math.cos(p.orbitRotation));

        // --- 物理场域干涉判定 ---
        const distToPlanet = Math.hypot(cursorX - p.cx, cursorY - p.cy);
        const domainRadius = n.clusterIndex === 0 ? 500 : (n.clusterIndex === 1 ? 320 : 250);

        if (distToPlanet < domainRadius) {
          const distToCursor = Math.hypot(cursorX - n.baseX, cursorY - n.baseY);
          const pullRange = 250; 

          if (distToCursor < pullRange) {
            n.isCaptured = true;
          }
        } else {
          n.isCaptured = false;
        }

        // --- ！！！极致显像输出：应用绝对单层与头顶指心矩阵 ！！！ ---
        ctx.save();
        
        if (n.isCaptured) {
          if (n.isRingAssigned) {
            // 【主干信条层】：被选中的粒子极其精准地嵌入基准位，形成绝对唯一单层光环
            const targetSlotAngle = cursorSpinAngle + (n.targetCursorSlot / targetLength) * Math.PI * 2;
            const targetRingX = cursorX + Math.cos(targetSlotAngle) * 125; // 轨道半径加大至 125px 确保绝佳间距
            const targetRingY = cursorY + Math.sin(targetSlotAngle) * 125;

            n.x += (targetRingX - n.x) * 0.18;
            n.y += (targetRingY - n.y) * 0.18;

            n.currentChar = creedString[n.targetCursorSlot];
            ctx.fillStyle = '#8EDB35'; 
            ctx.font = 'bold 15px sans-serif'; 

            // ！！！完美几何秩序：头顶精确指心 ！！！
            // 将字符输出原点移至当前坐标，旋转角度锁定为目标夹角 + $\pi/2$ (90度)
            ctx.translate(n.x, n.y);
            ctx.rotate(targetSlotAngle + Math.PI / 2);
            ctx.fillText(n.currentChar, 0, 0); 
          } else {
            // 【外围飞溅游离层】：未被选入文字环的多余粒子，仅作为被吸引的光带飞散在中心周围
            // 绝不直接拼成乱序文字干扰圆环阅读，保证画面既有被掠夺的宏大动感又绝对干净！
            const pullAngle = Math.atan2(cursorY - n.baseY, cursorX - n.baseX);
            n.x += (cursorX - Math.cos(pullAngle) * 80 - n.x) * 0.1;
            n.y += (cursorY - Math.sin(pullAngle) * 80 - n.y) * 0.1;

            n.currentChar = n.originalChar;
            ctx.fillStyle = 'rgba(142, 219, 53, 0.4)'; 
            ctx.font = `bold ${n.size * 0.8}px monospace`;
            ctx.translate(n.x, n.y);
            ctx.fillText(n.currentChar, 0, 0); 
          }
        } else {
          // 【母星引力崩溃回吸态】：干净利落地自动吸回原始星系阵地
          n.x += (n.baseX - n.x) * 0.12;
          n.y += (n.baseY - n.y) * 0.12;
          
          n.currentChar = n.originalChar;
          ctx.fillStyle = n.type === 'ring' ? 'rgba(142, 219, 53, 0.25)' : 'rgba(120, 120, 120, 0.35)';
          ctx.font = `bold ${n.size}px monospace`;
          ctx.translate(n.x, n.y);
          ctx.fillText(n.currentChar, 0, 0); 
        }

        ctx.restore();
      });

      requestAnimationFrame(renderUniverse);
    }

    function startUniverse() {
      if (mobileMotionQuery.matches) {
        canvas.style.visibility = 'hidden';
        ctx.clearRect(0, 0, width, height);
        return;
      }

      canvas.style.visibility = 'visible';
      renderUniverse();
    }

    // 等待字体加载完毕再开始渲染
    if (window.fontsReadyPromise) {
      window.fontsReadyPromise.then(startUniverse);
    } else if (document.fonts && document.fonts.ready) {
      document.fonts.ready.then(startUniverse);
    } else {
      startUniverse();
    }

    const chronologySection = document.querySelector('.chronology-section') as HTMLElement | null;
    const timelineMap = document.querySelector('.chronology-map') as HTMLElement | null;
    const timelineWorld = document.querySelector('[data-timeline-world]') as HTMLElement | null;
    const timelinePath = document.querySelector('[data-timeline-path]') as SVGPathElement | null;
    const timelineGhostPath = document.querySelector('.chronology-path.is-ghost') as SVGPathElement | null;
    const timelineHead = document.querySelector('[data-timeline-head]') as HTMLElement | null;
    const timelineNodes = Array.from(document.querySelectorAll('[data-timeline-node]')) as HTMLElement[];
    const timelineCurrent = document.querySelector('[data-timeline-current]') as HTMLElement | null;
    const mobileHomeQuery = window.matchMedia('(max-width: 899px)');
    let timelineNodeStops = [] as number[];
    let timelineScrollRaf: number | undefined;
    let timelineSpringRaf: number | undefined;
    let timelineSpringTime = 0;
    let targetTimelineProgress = 0;
    let visualTimelineProgress = 0;
    let timelineVelocity = 0;
    let lastTimelineScrollY = -1;
    let lockedTimelineStopIndex = -1;
    let lockedTimelineDirection = 0;
    let isTimelineLockReady = false;
    let visibleTimelineCardIndex = -1;
    let releasedTimelineStopIndex = -1;
    let releasedTimelineDirection = 0;
    let timelineScrollAnimationRaf: number | undefined;
    let timelineScrollAnimationTimeout: number | undefined;
    let timelineCameraFocusRatio = 0.54;
    let timelineVisibleCardSide: 'left' | 'right' = 'right';
    let hasTimelineCameraFocus = false;
    let timelineCameraRaf: number | undefined;
    let timelineCameraTime = 0;
    let hasTimelineCameraTransform = false;
    let timelineCameraX = 0;
    let timelineCameraY = 0;
    let timelineCameraScale = 1;
    let timelineCameraTargetX = 0;
    let timelineCameraTargetY = 0;
    let timelineCameraTargetScale = 1;
    let timelineCameraVelocityX = 0;
    let timelineCameraVelocityY = 0;
    let timelineCameraVelocityScale = 0;
    let stableMobileViewportWidth = window.innerWidth;
    let stableMobileViewportHeight = window.innerHeight;

    function getInteractionViewportHeight() {
      return window.innerWidth < 900 ? stableMobileViewportHeight : window.innerHeight;
    }

    function isMobileHomeFallback() {
      return mobileHomeQuery.matches;
    }

    function applyStableViewportMetrics() {
      const viewportHeight = getInteractionViewportHeight();
      document.documentElement.style.setProperty('--stable-app-height', `${viewportHeight}px`);

      chronologySection?.style.removeProperty('--timeline-section-height');
      chronologySection?.style.removeProperty('min-height');
    }

    function refreshStableViewportSize(force = false) {
      const widthDelta = Math.abs(window.innerWidth - stableMobileViewportWidth);
      const shouldRefresh = force || window.innerWidth >= 900 || widthDelta > 8;
      if (!shouldRefresh) return;

      stableMobileViewportWidth = window.innerWidth;
      stableMobileViewportHeight = window.innerHeight;
      applyStableViewportMetrics();
      hasTimelineCameraTransform = false;
      hasTimelineCameraFocus = false;
      timelineCameraVelocityX = 0;
      timelineCameraVelocityY = 0;
      timelineCameraVelocityScale = 0;
    }

    applyStableViewportMetrics();

    function getTimelineSectionTop() {
      if (!chronologySection) return 0;
      return chronologySection.offsetTop;
    }

    function getTimelineTravelDistance() {
      if (!chronologySection) return 1;
      return Math.max(1, chronologySection.offsetHeight - getInteractionViewportHeight());
    }

    function isNearInteractiveSection(section: HTMLElement, lead = 1.15, tail = 0.45) {
      const viewportHeight = getInteractionViewportHeight();
      const sectionTop = section.offsetTop;
      const sectionBottom = sectionTop + section.offsetHeight;
      return window.scrollY >= sectionTop - viewportHeight * lead && window.scrollY <= sectionBottom + viewportHeight * tail;
    }

    function stopTimelineMotion() {
      if (timelineSpringRaf) {
        window.cancelAnimationFrame(timelineSpringRaf);
        timelineSpringRaf = undefined;
      }
      if (timelineCameraRaf) {
        window.cancelAnimationFrame(timelineCameraRaf);
        timelineCameraRaf = undefined;
      }
      timelineVelocity = 0;
      timelineCameraVelocityX = 0;
      timelineCameraVelocityY = 0;
      timelineCameraVelocityScale = 0;
      hasTimelineCameraTransform = false;
      hasTimelineCameraFocus = false;
    }

    function setupTimelineGeometry() {
      if (!timelinePath || !timelineNodes.length) return;
      const points = timelineNodes.map((node) => ({
        node,
        x: Number(node.dataset.x || 0),
        y: Number(node.dataset.y || 0)
      }));
      const start = { x: 500, y: -20 };
      const end = { x: 520, y: 2140 };
      const pathD = `M ${start.x} ${start.y} ${points.map((point) => `L ${point.x} ${point.y}`).join(' ')} L ${end.x} ${end.y}`;
      timelinePath.setAttribute('d', pathD);
      timelineGhostPath?.setAttribute('d', pathD);

      const pathPoints = [start, ...points, end];
      const segmentLengths = pathPoints.slice(1).map((point, index) => {
        const previous = pathPoints[index];
        return Math.hypot(point.x - previous.x, point.y - previous.y);
      });
      const totalLength = segmentLengths.reduce((sum, length) => sum + length, 0);
      let accumulated = 0;

      timelineNodeStops = points.map((point, index) => {
        accumulated += segmentLengths[index];
        const threshold = totalLength ? accumulated / totalLength : 0;
        const previous = pathPoints[index];
        const next = pathPoints[index + 2];
        const protrudesRight = point.x >= (previous.x + next.x) / 2;
        point.node.dataset.threshold = String(threshold);
        point.node.dataset.cardSide = protrudesRight ? 'right' : 'left';
        return threshold;
      }).filter((stop) => stop > 0 && stop < 1).sort((a, b) => a - b);
    }

    function mapTimelineScrollProgress(rawProgress: number, direction = 0) {
      const raw = Math.min(Math.max(rawProgress, 0), 1);
      return raw;
    }

    function setTimelineTarget(progress: number, immediate = false) {
      targetTimelineProgress = Math.min(Math.max(progress, 0), 1);
      const isMobileTimeline = window.innerWidth < 900;
      const isMobileJump = isMobileTimeline && Math.abs(targetTimelineProgress - visualTimelineProgress) > 0.28;

      if (immediate || isMobileTimeline || isMobileJump) {
        if (timelineSpringRaf) {
          window.cancelAnimationFrame(timelineSpringRaf);
          timelineSpringRaf = undefined;
        }
        if (isMobileTimeline || isMobileJump) {
          if (timelineCameraRaf) {
            window.cancelAnimationFrame(timelineCameraRaf);
            timelineCameraRaf = undefined;
          }
          hasTimelineCameraTransform = false;
          timelineCameraVelocityX = 0;
          timelineCameraVelocityY = 0;
          timelineCameraVelocityScale = 0;
        }
        visualTimelineProgress = targetTimelineProgress;
        timelineVelocity = 0;
        setTimelineProgress(visualTimelineProgress);
        return;
      }

      if (Math.abs(targetTimelineProgress - visualTimelineProgress) < 0.0002 && Math.abs(timelineVelocity) < 0.0002) {
        return;
      }

      if (!timelineSpringRaf) {
        timelineSpringTime = performance.now();
        timelineSpringRaf = window.requestAnimationFrame(updateTimelineSpring);
      }
    }

    function updateTimelineSpring(timestamp: number) {
      const deltaTime = Math.min(0.032, Math.max(0.001, (timestamp - timelineSpringTime) / 1000));
      timelineSpringTime = timestamp;

      const displacement = targetTimelineProgress - visualTimelineProgress;
      const tension = 190;
      const damping = 15.5;

      timelineVelocity += displacement * tension * deltaTime;
      timelineVelocity *= Math.exp(-damping * deltaTime);
      visualTimelineProgress += timelineVelocity * deltaTime;

      if (Math.abs(displacement) < 0.00035 && Math.abs(timelineVelocity) < 0.00045) {
        visualTimelineProgress = targetTimelineProgress;
        timelineVelocity = 0;
        setTimelineProgress(visualTimelineProgress);
        timelineSpringRaf = undefined;
        return;
      }

      setTimelineProgress(visualTimelineProgress);
      timelineSpringRaf = window.requestAnimationFrame(updateTimelineSpring);
    }

    function setTimelineProgress(progress: number) {
      if (!chronologySection) return;
      const clamped = Math.min(Math.max(progress, 0), 1);
      chronologySection.style.setProperty('--timeline-progress', String(clamped));
      syncTimelineCamera(clamped);

      let activeCount = 0;
      timelineNodes.forEach((node) => {
        const threshold = Number(node.dataset.threshold || 0);
        const isActive = clamped + 0.002 >= threshold;
        node.classList.toggle('is-active', isActive);
        node.classList.remove('is-current');
        node.classList.remove('is-timeline-locked');
        if (isActive) activeCount += 1;
      });

      if (visibleTimelineCardIndex >= 0 && window.innerWidth >= 900) {
        timelineNodes[visibleTimelineCardIndex]?.classList.add('is-current', 'is-active');
        activeCount = Math.max(activeCount, visibleTimelineCardIndex + 1);
      }

      const isMobileTimelineActive = window.innerWidth < 900 && (!worksSection || window.scrollY < worksSection.offsetTop - 4);
      if (isMobileTimelineActive && timelineNodeStops.length) {
        const nearestIndex = timelineNodeStops.reduce((closestIndex, stop, index) => (
          Math.abs(stop - clamped) < Math.abs(timelineNodeStops[closestIndex] - clamped) ? index : closestIndex
        ), 0);
        timelineNodes[nearestIndex]?.classList.add('is-current', 'is-active');
        activeCount = Math.max(activeCount, nearestIndex + 1);
      }

      if (lockedTimelineStopIndex >= 0 && isTimelineLockReady) {
        timelineNodes[lockedTimelineStopIndex]?.classList.add('is-timeline-locked');
      } else if (lockedTimelineStopIndex >= 0 && visibleTimelineCardIndex < 0) {
        activeCount = Math.min(activeCount, lockedTimelineStopIndex);
      }

      if (timelineCurrent) timelineCurrent.textContent = String(activeCount).padStart(2, '0');
    }

    function smoothTimelineStep(edgeStart: number, edgeEnd: number, value: number) {
      const range = Math.max(edgeEnd - edgeStart, 0.0001);
      const t = Math.min(Math.max((value - edgeStart) / range, 0), 1);
      return t * t * (3 - 2 * t);
    }

    function easeTimelineMotion(t: number) {
      return t < 0.5
        ? 4 * t * t * t
        : 1 - Math.pow(-2 * t + 2, 3) / 2;
    }

    function hideTimelineVisibleCard() {
      timelineNodes.forEach((node) => {
        node.classList.remove('is-current');
        node.classList.remove('is-timeline-locked');
      });
      visibleTimelineCardIndex = -1;
    }

    function clearTimelineLockClass() {
      timelineNodes.forEach((node) => {
        node.classList.remove('is-timeline-locked');
      });
    }

    function revealTimelineLockedNode(index: number) {
      isTimelineLockReady = lockedTimelineStopIndex === index;
      if (!isTimelineLockReady) return;
      visibleTimelineCardIndex = index;
      const side = timelineNodes[index]?.dataset.cardSide;
      timelineVisibleCardSide = side === 'left' ? 'left' : 'right';
      setTimelineTarget(timelineNodeStops[index]);
      setTimelineProgress(timelineNodeStops[index]);
    }

    function animateTimelineScrollTo(targetY: number, duration = 360, onComplete?: () => void) {
      if (timelineScrollAnimationRaf) {
        window.cancelAnimationFrame(timelineScrollAnimationRaf);
        timelineScrollAnimationRaf = undefined;
      }
      if (timelineScrollAnimationTimeout) {
        window.clearTimeout(timelineScrollAnimationTimeout);
        timelineScrollAnimationTimeout = undefined;
      }

      const startY = window.scrollY;
      const distance = targetY - startY;
      const startedAt = performance.now();
      let completed = false;

      const finish = () => {
        if (completed) return;
        completed = true;
        if (timelineScrollAnimationRaf) {
          window.cancelAnimationFrame(timelineScrollAnimationRaf);
          timelineScrollAnimationRaf = undefined;
        }
        if (timelineScrollAnimationTimeout) {
          window.clearTimeout(timelineScrollAnimationTimeout);
          timelineScrollAnimationTimeout = undefined;
        }
        window.scrollTo({ top: targetY, behavior: 'auto' });
        requestTimelineScrollSync();
        onComplete?.();
      };

      const tick = (timestamp: number) => {
        if (completed) return;
        const elapsed = timestamp - startedAt;
        const t = Math.min(Math.max(elapsed / duration, 0), 1);
        const eased = easeTimelineMotion(t);
        window.scrollTo({ top: startY + distance * eased, behavior: 'auto' });
        requestTimelineScrollSync();

        if (t < 1) {
          timelineScrollAnimationRaf = window.requestAnimationFrame(tick);
          return;
        }

        finish();
      };

      timelineScrollAnimationTimeout = window.setTimeout(finish, duration + 120);
      timelineScrollAnimationRaf = window.requestAnimationFrame(tick);
    }

    function lockTimelineNode(index: number, direction: number) {
      lockedTimelineStopIndex = index;
      lockedTimelineDirection = direction;
      isTimelineLockReady = false;
      hideTimelineVisibleCard();
      setTimelineTarget(timelineNodeStops[index]);
    }

    function releaseTimelineNode(direction: number) {
      if (lockedTimelineStopIndex < 0) return;
      const releasedIndex = lockedTimelineStopIndex;
      lockedTimelineStopIndex = -1;
      lockedTimelineDirection = 0;
      isTimelineLockReady = false;
      releasedTimelineStopIndex = releasedIndex;
      releasedTimelineDirection = direction;
      clearTimelineLockClass();
    }

    function getTimelineCameraState(progress: number, currentStopIndex: number) {
      return { progress, stopIndex: currentStopIndex };
    }

    function snapToDevicePixel(value: number) {
      const ratio = Math.max(1, window.devicePixelRatio || 1);
      return Math.round(value * ratio) / ratio;
    }

    function applyTimelineCameraTransform() {
      if (!chronologySection) return;
      const shouldSnap = window.innerWidth < 900;
      const cameraX = shouldSnap ? snapToDevicePixel(timelineCameraX) : timelineCameraX;
      const cameraY = shouldSnap ? snapToDevicePixel(timelineCameraY) : timelineCameraY;
      const gridX = shouldSnap ? Math.round(cameraX * 0.08) : cameraX * 0.08;
      const gridY = shouldSnap ? Math.round(cameraY * 0.08) : cameraY * 0.08;

      chronologySection.style.setProperty('--timeline-camera-x', `${cameraX}px`);
      chronologySection.style.setProperty('--timeline-camera-y', `${cameraY}px`);
      chronologySection.style.setProperty('--timeline-camera-scale', String(timelineCameraScale));
      chronologySection.style.setProperty('--timeline-grid-x', `${gridX}px`);
      chronologySection.style.setProperty('--timeline-grid-y', `${gridY}px`);
    }

    function setTimelineCameraTarget(x: number, y: number, scale: number) {
      timelineCameraTargetX = x;
      timelineCameraTargetY = y;
      timelineCameraTargetScale = scale;

      if (window.innerWidth < 900) {
        if (timelineCameraRaf) {
          window.cancelAnimationFrame(timelineCameraRaf);
          timelineCameraRaf = undefined;
        }
        hasTimelineCameraTransform = true;
        timelineCameraX = x;
        timelineCameraY = y;
        timelineCameraScale = scale;
        timelineCameraVelocityX = 0;
        timelineCameraVelocityY = 0;
        timelineCameraVelocityScale = 0;
        applyTimelineCameraTransform();
        return;
      }

      if (!hasTimelineCameraTransform) {
        hasTimelineCameraTransform = true;
        timelineCameraX = x;
        timelineCameraY = y;
        timelineCameraScale = scale;
        applyTimelineCameraTransform();
        return;
      }

      if (!timelineCameraRaf) {
        timelineCameraTime = performance.now();
        timelineCameraRaf = window.requestAnimationFrame(updateTimelineCameraSpring);
      }
    }

    function updateTimelineCameraSpring(timestamp: number) {
      const deltaTime = Math.min(0.032, Math.max(0.001, (timestamp - timelineCameraTime) / 1000));
      timelineCameraTime = timestamp;

      const tension = 105;
      const damping = 24;
      const scaleTension = 105;
      const scaleDamping = 22;
      const displacementX = timelineCameraTargetX - timelineCameraX;
      const displacementY = timelineCameraTargetY - timelineCameraY;
      const displacementScale = timelineCameraTargetScale - timelineCameraScale;

      timelineCameraVelocityX += displacementX * tension * deltaTime;
      timelineCameraVelocityY += displacementY * tension * deltaTime;
      timelineCameraVelocityScale += displacementScale * scaleTension * deltaTime;
      timelineCameraVelocityX *= Math.exp(-damping * deltaTime);
      timelineCameraVelocityY *= Math.exp(-damping * deltaTime);
      timelineCameraVelocityScale *= Math.exp(-scaleDamping * deltaTime);
      const maxCameraVelocity = 820;
      if (Math.abs(timelineCameraVelocityX) > maxCameraVelocity) {
        timelineCameraVelocityX = Math.sign(timelineCameraVelocityX) * maxCameraVelocity;
      }
      if (Math.abs(timelineCameraVelocityY) > maxCameraVelocity) {
        timelineCameraVelocityY = Math.sign(timelineCameraVelocityY) * maxCameraVelocity;
      }
      timelineCameraX += timelineCameraVelocityX * deltaTime;
      timelineCameraY += timelineCameraVelocityY * deltaTime;
      timelineCameraScale += timelineCameraVelocityScale * deltaTime;

      applyTimelineCameraTransform();

      const isSettled =
        Math.abs(displacementX) < 0.12 &&
        Math.abs(displacementY) < 0.12 &&
        Math.abs(displacementScale) < 0.0004 &&
        Math.abs(timelineCameraVelocityX) < 0.12 &&
        Math.abs(timelineCameraVelocityY) < 0.12 &&
        Math.abs(timelineCameraVelocityScale) < 0.0004;

      if (isSettled) {
        timelineCameraX = timelineCameraTargetX;
        timelineCameraY = timelineCameraTargetY;
        timelineCameraScale = timelineCameraTargetScale;
        applyTimelineCameraTransform();
        timelineCameraRaf = undefined;
        return;
      }

      timelineCameraRaf = window.requestAnimationFrame(updateTimelineCameraSpring);
    }

    function syncTimelineCamera(progress: number) {
      if (!chronologySection || !timelineMap || !timelineWorld || !timelinePath) return;
      const pathLength = timelinePath.getTotalLength();
      const headPoint = timelinePath.getPointAtLength(pathLength * progress);
      const mapRect = timelineMap.getBoundingClientRect();
      const isMobile = window.innerWidth < 900;
      const scale = isMobile ? 1.02 : window.innerWidth >= 1440 ? 1.72 : 1.55;
      const currentStopIndex = timelineNodeStops.reduce((activeIndex, stop, index) => (
        progress + 0.002 >= stop ? index : activeIndex
      ), -1);
      const cameraState = getTimelineCameraState(progress, currentStopIndex);
      const cameraPoint = timelinePath.getPointAtLength(pathLength * cameraState.progress);
      const targetFocusXRatio = isMobile ? 0.5 : timelineVisibleCardSide === 'right' ? 0.44 : 0.64;
      if (!hasTimelineCameraFocus) {
        timelineCameraFocusRatio = targetFocusXRatio;
        hasTimelineCameraFocus = true;
      } else {
        timelineCameraFocusRatio += (targetFocusXRatio - timelineCameraFocusRatio) * 0.16;
      }
      const focusXRatio = timelineCameraFocusRatio;
      const focusX = window.innerWidth * focusXRatio - mapRect.left;
      const focusY = getInteractionViewportHeight() * (isMobile ? 0.5 : 0.66) - mapRect.top;
      const worldX = cameraPoint.x;
      const worldY = cameraPoint.y;

      if (timelineHead) {
        timelineHead.style.left = `${headPoint.x}px`;
        timelineHead.style.top = `${headPoint.y}px`;
      }

      timelinePath.style.strokeDasharray = `${pathLength}`;
      timelinePath.style.strokeDashoffset = `${pathLength * (1 - progress)}`;

      timelineNodes.forEach((node) => {
        const threshold = Number(node.dataset.threshold || 0);
        const nodePoint = timelinePath.getPointAtLength(pathLength * threshold);
        node.style.setProperty('--node-x', `${nodePoint.x}px`);
        node.style.setProperty('--node-y', `${nodePoint.y}px`);
      });

      setTimelineCameraTarget(focusX - worldX * scale, focusY - worldY * scale, scale);
    }

    function syncTimelineToScroll() {
      if (!chronologySection) return;
      const rawProgress = (window.scrollY - getTimelineSectionTop()) / getTimelineTravelDistance();
      if (
        releasedTimelineStopIndex >= 0 &&
        Math.abs(rawProgress - timelineNodeStops[releasedTimelineStopIndex]) > 0.025
      ) {
        releasedTimelineStopIndex = -1;
        releasedTimelineDirection = 0;
      }

      const progress = lockedTimelineStopIndex >= 0
        ? timelineNodeStops[lockedTimelineStopIndex]
        : mapTimelineScrollProgress(rawProgress);
      setTimelineTarget(progress);
    }

    function requestTimelineScrollSync() {
      if (chronologySection && !isNearInteractiveSection(chronologySection)) return;
      if (timelineScrollRaf) return;
      timelineScrollRaf = window.requestAnimationFrame(() => {
        timelineScrollRaf = undefined;
        syncTimelineToScroll();
      });
    }

    function handleTimelineWheel(event: WheelEvent) {
      if (!chronologySection || window.innerWidth < 900) return;
      const sectionTop = getTimelineSectionTop();
      const sectionBottom = sectionTop + chronologySection.offsetHeight - window.innerHeight;
      const scrollY = window.scrollY;
      const rawDelta = normalizeWheelDelta(event);
      const isInsideTimeline = scrollY >= sectionTop - 2 && scrollY <= sectionBottom + 2;
      const isLeavingUp = scrollY <= sectionTop + 2 && rawDelta < 0;
      const isLeavingDown = scrollY >= sectionBottom - 2 && rawDelta > 0;

      if (!isInsideTimeline || isLeavingUp || isLeavingDown || Math.abs(rawDelta) < 1) return;

      event.preventDefault();
      const direction = Math.sign(rawDelta);
      const travelDistance = getTimelineTravelDistance();
      const currentRawProgress = (scrollY - sectionTop) / travelDistance;

      if (lockedTimelineStopIndex >= 0) {
        if (!isTimelineLockReady) {
          const lockedStop = timelineNodeStops[lockedTimelineStopIndex];
          const lockedStopY = sectionTop + travelDistance * lockedStop;
          if (Math.abs(scrollY - lockedStopY) <= 3 || Math.abs(currentRawProgress - lockedStop) <= 0.003) {
            revealTimelineLockedNode(lockedTimelineStopIndex);
          } else {
            setTimelineTarget(lockedStop);
            if (!timelineScrollAnimationRaf) {
              animateTimelineScrollTo(lockedStopY, 280, () => {
                window.scrollTo({ top: lockedStopY, behavior: 'auto' });
                revealTimelineLockedNode(lockedTimelineStopIndex);
                requestTimelineScrollSync();
              });
            }
          }
          return;
        }

        const stopIndex = lockedTimelineStopIndex;
        const releaseDirection = direction;
        const stopY = sectionTop + travelDistance * timelineNodeStops[stopIndex];
        setTimelineTarget(timelineNodeStops[lockedTimelineStopIndex]);
        releaseTimelineNode(releaseDirection);
        animateTimelineScrollTo(
          Math.min(Math.max(stopY + releaseDirection * Math.max(32, window.innerHeight * 0.055), sectionTop), sectionBottom),
          420,
          () => {
            requestTimelineScrollSync();
          }
        );

        return;
      }

      if (releasedTimelineStopIndex >= 0 && timelineScrollAnimationRaf) {
        return;
      }

      const maxStep = Math.max(30, Math.min(window.innerHeight * 0.07, 58));
      const cappedDelta = direction * Math.min(Math.abs(rawDelta), maxStep);
      let nextY = Math.min(Math.max(scrollY + cappedDelta, sectionTop), sectionBottom);
      let stopToLock = -1;

      timelineNodeStops.forEach((stop, index) => {
        if (stopToLock >= 0) return;
        const isRecentlyReleasedStop = releasedTimelineStopIndex === index;
        if (
          isRecentlyReleasedStop &&
          (releasedTimelineDirection === direction || Math.abs(currentRawProgress - stop) < 0.04)
        ) return;

        const stopY = sectionTop + travelDistance * stop;
        const crossesDown = direction > 0 && scrollY < stopY && nextY >= stopY;
        const crossesUp = direction < 0 && scrollY > stopY && nextY <= stopY;
        const arrivalWindow = Math.max(64, window.innerHeight * 0.08);
        const approachesDown = direction > 0 && scrollY < stopY && stopY - scrollY <= arrivalWindow;
        const approachesUp = direction < 0 && scrollY > stopY && scrollY - stopY <= arrivalWindow;
        if (crossesDown || crossesUp || approachesDown || approachesUp) stopToLock = index;
      });

      if (stopToLock >= 0) {
        const stopY = sectionTop + travelDistance * timelineNodeStops[stopToLock];
        lockTimelineNode(stopToLock, direction);
        animateTimelineScrollTo(stopY, 360, () => {
          window.scrollTo({ top: stopY, behavior: 'auto' });
          revealTimelineLockedNode(stopToLock);
          requestTimelineScrollSync();
        });
        return;
      }

      window.scrollTo({ top: nextY, behavior: 'auto' });
      requestTimelineScrollSync();
    }

    function monitorTimelineScroll() {
      if (!chronologySection) {
        window.requestAnimationFrame(monitorTimelineScroll);
        return;
      }

      if (!isNearInteractiveSection(chronologySection)) {
        lastTimelineScrollY = window.scrollY;
        stopTimelineMotion();
        window.requestAnimationFrame(monitorTimelineScroll);
        return;
      }

      if (window.scrollY !== lastTimelineScrollY) {
        lastTimelineScrollY = window.scrollY;
        syncTimelineToScroll();
      }
      window.requestAnimationFrame(monitorTimelineScroll);
    }

    const worksSection = document.querySelector('.works-section') as HTMLElement | null;
    const worksPin = document.querySelector('.works-pin') as HTMLElement | null;
    const worksStage = document.querySelector('.works-stage') as HTMLElement | null;
    const worksCards = Array.from(document.querySelectorAll('[data-work-card]')) as HTMLElement[];
    const worksCategories = Array.from(document.querySelectorAll('[data-work-category].works-category')) as HTMLButtonElement[];
    const worksNotes = Array.from(document.querySelectorAll('[data-work-note]')) as HTMLElement[];
    const worksCurrent = document.querySelector('[data-work-current]') as HTMLElement | null;
    const worksTotal = document.querySelector('[data-work-total]') as HTMLElement | null;
    let activeWorkIndex = 0;
    let visualWorkProgress = 0;
    let targetWorkProgress = 0;
    let worksScrollRaf: number | undefined;
    let lastWorksScrollY = -1;

    function isMobileWorksLayout() {
      return isMobileHomeFallback();
    }

    function getWorksIntroHoldDistance() {
      return getInteractionViewportHeight() * (isMobileWorksLayout() ? 0.58 : 1.25);
    }

    function applyWorksViewportMetrics() {
      if (!worksSection) return;

      if (isMobileWorksLayout()) {
        worksSection.style.removeProperty('--works-intro-hold');
        worksSection.style.removeProperty('--works-step-scroll');
        worksSection.style.removeProperty('min-height');
      } else {
        worksSection.style.removeProperty('--works-intro-hold');
        worksSection.style.removeProperty('--works-step-scroll');
        worksSection.style.removeProperty('min-height');
      }
    }

    function stopWorksVideos(except?: HTMLElement) {
      worksCards.forEach((card) => {
        if (card === except) return;
        const video = card.querySelector('video') as HTMLVideoElement | null;
        if (!video) return;
        const image = card.querySelector('img') as HTMLImageElement | null;
        video.pause();
        video.style.removeProperty('opacity');
        image?.style.removeProperty('opacity');
        card.classList.remove('is-playing');
      });
    }

    function syncWorksMeta() {
      if (!worksCards.length) return;
      const activeCard = worksCards[activeWorkIndex];
      const activeCategory = activeCard?.dataset.workCategory;

      worksCategories.forEach((button) => {
        button.classList.toggle('is-active', button.dataset.workCategory === activeCategory);
      });

      worksNotes.forEach((note) => {
        note.classList.toggle('is-active', note.dataset.workNote === activeCategory);
      });

      if (worksCurrent) worksCurrent.textContent = String(activeWorkIndex + 1).padStart(2, '0');
      if (worksTotal) worksTotal.textContent = String(worksCards.length).padStart(2, '0');
      if (isMobileWorksLayout()) {
        const overallProgress = worksCards.length > 1 ? activeWorkIndex / (worksCards.length - 1) : 1;
        worksSection?.style.setProperty('--work-step-progress', String(overallProgress));
      }
    }

    function renderWorksStack(progress = activeWorkIndex) {
      if (!worksCards.length) return;

      worksCards.forEach((card, index) => {
        const offset = index - activeWorkIndex;
        const absOffset = Math.abs(offset);
        const depth = Math.min(absOffset, 5);
        const isActive = index === activeWorkIndex;
        const isPast = offset < 0;
        const isUpcoming = offset > 0;
        const isMobile = isMobileWorksLayout();
        const isMobileVisible = isMobile && offset >= 0 && offset <= 3;
        const parkedX = offset < 0 ? '-64vw' : '64vw';
        const parkedRotate = offset < 0 ? '-2.8deg' : '2.8deg';

        card.classList.toggle('is-active', isActive);
        card.classList.toggle('is-past', isPast);
        card.classList.toggle('is-upcoming', isUpcoming);
        card.style.setProperty('--offset', String(offset));
        card.style.setProperty('--abs-offset', String(absOffset));
        card.style.setProperty('--depth', String(depth));
        card.style.setProperty('--stack-order', String(isMobile ? 1000 - Math.max(offset, 0) : 1000 - Math.round(absOffset * 20)));
        card.style.opacity = isActive || isMobileVisible ? String(isActive ? 1 : Math.max(0.38, 0.78 - offset * 0.14)) : '0';
        card.style.pointerEvents = isActive ? 'auto' : 'none';
        card.style.transform = isMobile
          ? `translate(-50%, calc(-50% + ${Math.max(offset, 0) * 0.72}rem)) rotate(${Math.max(offset, 0) * -1.1}deg) scale(${1 - Math.max(offset, 0) * 0.035})`
          : isActive
            ? 'translate(-50%, -50%) rotate(0deg) scale(1)'
            : `translate(calc(-50% + ${parkedX}), -50%) rotate(${parkedRotate}) scale(0.985)`;
        card.style.visibility = isActive || isMobileVisible ? 'visible' : 'hidden';
      });
    }

    function updateWorksStack() {
      if (!worksCards.length) return;
      renderWorksStack(visualWorkProgress);
      syncWorksMeta();
      const activeCard = worksCards[activeWorkIndex];

      worksCards.forEach((card, index) => {
        if (index !== activeWorkIndex) {
          const video = card.querySelector('video') as HTMLVideoElement | null;
          const image = card.querySelector('img') as HTMLImageElement | null;
          video?.style.removeProperty('opacity');
          image?.style.removeProperty('opacity');
          card.classList.remove('is-playing');
        }
      });

      stopWorksVideos(activeCard);
    }

    function setActiveWorkIndex(index: number) {
      const nextIndex = Math.min(Math.max(index, 0), worksCards.length - 1);
      if (nextIndex === activeWorkIndex) return;
      activeWorkIndex = nextIndex;
      updateWorksStack();
    }

    function setWorksProgress(progress: number) {
      targetWorkProgress = Math.min(Math.max(progress, 0), worksCards.length - 1);
      visualWorkProgress = targetWorkProgress;
      const nextIndex = Math.min(Math.floor(targetWorkProgress + 0.0001), worksCards.length - 1);
      const stepProgress = nextIndex >= worksCards.length - 1 ? 1 : targetWorkProgress - nextIndex;
      worksSection?.style.setProperty('--work-step-progress', String(Math.min(Math.max(stepProgress, 0), 1)));
      setActiveWorkIndex(nextIndex);
    }

    function getWorksSectionTop() {
      if (!worksSection) return 0;
      return worksSection.offsetTop;
    }

    function getWorksTravelDistance() {
      if (!worksSection) return 1;
      const introHold = getWorksIntroHoldDistance();
      return Math.max(1, worksSection.offsetHeight - getInteractionViewportHeight() - introHold);
    }

    function syncWorksStackToScroll() {
      if (!worksSection || !worksCards.length) return;
      const introHold = getWorksIntroHoldDistance();
      const progress = (window.scrollY - getWorksSectionTop() - introHold) / getWorksTravelDistance();
      const clampedProgress = Math.min(Math.max(progress, 0), 1);
      setWorksProgress(clampedProgress * (worksCards.length - 1));
    }

    function requestWorksScrollSync() {
      if (worksSection && !isNearInteractiveSection(worksSection)) return;
      if (worksScrollRaf) return;
      worksScrollRaf = window.requestAnimationFrame(() => {
        worksScrollRaf = undefined;
        syncWorksStackToScroll();
      });
    }

    function normalizeWheelDelta(event: WheelEvent) {
      if (event.deltaMode === 1) return event.deltaY * 16;
      if (event.deltaMode === 2) return event.deltaY * window.innerHeight;
      return event.deltaY;
    }

    function handleWorksWheel(event: WheelEvent) {
      if (!worksSection || !worksCards.length || window.innerWidth < 900) return;
      const sectionTop = getWorksSectionTop();
      const sectionBottom = sectionTop + worksSection.offsetHeight - window.innerHeight;
      const scrollY = window.scrollY;
      const rawDelta = normalizeWheelDelta(event);
      const isInsideWorks = scrollY >= sectionTop - 2 && scrollY <= sectionBottom + 2;
      const isLeavingUp = scrollY <= sectionTop + 2 && rawDelta < 0;
      const isLeavingDown = scrollY >= sectionBottom - 2 && rawDelta > 0;

      if (!isInsideWorks || isLeavingUp || isLeavingDown || Math.abs(rawDelta) < 1) return;

      event.preventDefault();
      const maxStep = Math.max(36, Math.min(window.innerHeight * 0.09, 72));
      const cappedDelta = Math.sign(rawDelta) * Math.min(Math.abs(rawDelta), maxStep);
      const nextY = Math.min(Math.max(scrollY + cappedDelta, sectionTop), sectionBottom);
      window.scrollTo({ top: nextY, behavior: 'auto' });
      requestWorksScrollSync();
    }

    function monitorWorksScroll() {
      if (worksSection && !isNearInteractiveSection(worksSection)) {
        lastWorksScrollY = window.scrollY;
        window.requestAnimationFrame(monitorWorksScroll);
        return;
      }

      if (window.scrollY !== lastWorksScrollY) {
        lastWorksScrollY = window.scrollY;
        syncWorksStackToScroll();
      }
      window.requestAnimationFrame(monitorWorksScroll);
    }

    function scrollToWorkIndex(index: number) {
      if (!worksSection || !worksCards.length) return;
      const targetIndex = Math.min(Math.max(index, 0), worksCards.length - 1);
      if (isMobileWorksLayout()) {
        setActiveWorkIndex(targetIndex);
        return;
      }
      const ratio = worksCards.length > 1 ? targetIndex / (worksCards.length - 1) : 0;
      const introHold = getWorksIntroHoldDistance();
      const targetY = getWorksSectionTop() + introHold + getWorksTravelDistance() * ratio;
      window.scrollTo({ top: targetY, behavior: 'smooth' });
      setWorksProgress(targetIndex);
      setActiveWorkIndex(targetIndex);
    }

    function toggleWorksVideo(card: HTMLElement) {
      if (!card.classList.contains('is-active') || card.dataset.workKind !== 'video') return;
      const video = card.querySelector('video') as HTMLVideoElement | null;
      if (!video) return;
      stopWorksVideos(card);
      video.controls = true;
      if (video.paused) {
        if (video.readyState === 0) video.load();
        video.muted = false;
        video.removeAttribute('muted');
        video.volume = Math.max(video.volume || 0, 0.85);
        const image = card.querySelector('img') as HTMLImageElement | null;
        video.style.setProperty('opacity', '1', 'important');
        image?.style.setProperty('opacity', '0', 'important');
        card.classList.add('is-playing');
        video.play().then(() => {
          card.classList.add('is-playing');
        }).catch((error) => {
          card.dataset.videoError = error?.name || 'play-failed';
          card.classList.remove('is-playing');
        });
      } else {
        video.pause();
        const image = card.querySelector('img') as HTMLImageElement | null;
        video.style.removeProperty('opacity');
        image?.style.removeProperty('opacity');
        card.classList.remove('is-playing');
      }
    }

    function handleInteractiveResize() {
      const widthDelta = Math.abs(window.innerWidth - stableMobileViewportWidth);
      const heightDelta = Math.abs(window.innerHeight - stableMobileViewportHeight);
      const isMobileAddressBarResize = window.innerWidth < 900 && widthDelta <= 8 && heightDelta > 0;

      refreshStableViewportSize();
      applyWorksViewportMetrics();
      if (isMobileAddressBarResize) return;

      if (!isMobileHomeFallback()) {
        requestTimelineScrollSync();
        requestWorksScrollSync();
      } else {
        updateWorksStack();
      }
    }

    function activateMobileTimelineFallback() {
      stopTimelineMotion();
      chronologySection?.style.setProperty('--timeline-progress', '1');
      timelineNodes.forEach((node) => {
        node.classList.remove('is-current', 'is-timeline-locked');
        node.classList.add('is-active');
      });
      if (timelineCurrent) timelineCurrent.textContent = String(timelineNodes.length).padStart(2, '0');
    }

    if (chronologySection) {
      setupTimelineGeometry();
      if (isMobileHomeFallback()) {
        activateMobileTimelineFallback();
      } else {
        const initialTimelineRaw = (window.scrollY - getTimelineSectionTop()) / getTimelineTravelDistance();
        setTimelineTarget(mapTimelineScrollProgress(initialTimelineRaw), true);
        monitorTimelineScroll();
        window.addEventListener('scroll', requestTimelineScrollSync, { passive: true });
        window.addEventListener('wheel', handleTimelineWheel, { passive: false });
      }
      window.addEventListener('resize', handleInteractiveResize);
    }

    if (worksCards.length) {
      worksSection?.style.setProperty('--works-count', String(worksCards.length));
      applyWorksViewportMetrics();
      updateWorksStack();
      if (!isMobileWorksLayout()) {
        syncWorksStackToScroll();
        monitorWorksScroll();
        window.addEventListener('scroll', requestWorksScrollSync, { passive: true });
        window.addEventListener('wheel', handleWorksWheel, { passive: false });
      }
      window.addEventListener('resize', handleInteractiveResize);

      worksCategories.forEach((button) => {
        button.addEventListener('click', () => {
          if (button.getAttribute('aria-disabled') === 'true') return;
          const category = button.dataset.workCategory;
          const targetIndex = worksCards.findIndex((card) => card.dataset.workCategory === category);
          if (targetIndex < 0) return;
          scrollToWorkIndex(targetIndex);
        });
      });

      worksCards.forEach((card) => {
        const playButton = card.querySelector('.works-play') as HTMLButtonElement | null;
        playButton?.addEventListener('click', (event) => {
          event.preventDefault();
          event.stopPropagation();
          toggleWorksVideo(card);
        });

        card.addEventListener('click', (event) => {
          const target = event.target as HTMLElement;
          if (target.closest('a') || target.closest('video')) return;
          if (isMobileWorksLayout() && card.dataset.workKind !== 'video') {
            setActiveWorkIndex((activeWorkIndex + 1) % worksCards.length);
            return;
          }
          toggleWorksVideo(card);
        });
      });

      let worksTouchStartX = 0;
      let worksTouchStartY = 0;
      worksStage?.addEventListener('touchstart', (event) => {
        const touch = event.touches[0];
        if (!touch) return;
        worksTouchStartX = touch.clientX;
        worksTouchStartY = touch.clientY;
      }, { passive: true });

      worksStage?.addEventListener('touchend', (event) => {
        if (!isMobileWorksLayout()) return;
        const touch = event.changedTouches[0];
        if (!touch) return;
        const deltaX = touch.clientX - worksTouchStartX;
        const deltaY = touch.clientY - worksTouchStartY;
        if (Math.abs(deltaX) < 42 || Math.abs(deltaX) < Math.abs(deltaY) * 1.15) return;
        setActiveWorkIndex(activeWorkIndex + (deltaX < 0 ? 1 : -1));
      }, { passive: true });
    }

  </script>

  <script type="module" is:inline>
    const profileModelPanel = document.querySelector('.profile-model-panel');
    const profileModelCanvas = document.getElementById('profile-model-canvas');

    if (profileModelPanel && profileModelCanvas && !window.matchMedia('(max-width: 899px)').matches) {
      const THREE = await import('three');
      const { OrbitControls } = await import('three/addons/controls/OrbitControls.js');
      const { GLTFLoader } = await import('three/addons/loaders/GLTFLoader.js');

      const scene = new THREE.Scene();
      const camera = new THREE.PerspectiveCamera(32, 1, 0.1, 100);
      camera.position.set(3.6, 2.2, 5.4);

      const renderer = new THREE.WebGLRenderer({
        alpha: true,
        antialias: true,
        canvas: profileModelCanvas,
        powerPreference: 'high-performance'
      });
      renderer.setClearColor(0x000000, 0);
      renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 1.8));
      renderer.outputColorSpace = THREE.SRGBColorSpace;
      renderer.toneMapping = THREE.ACESFilmicToneMapping;
      renderer.toneMappingExposure = 1.05;

      const controls = new OrbitControls(camera, renderer.domElement);
      controls.enableDamping = true;
      controls.dampingFactor = 0.08;
      controls.enablePan = false;
      controls.minDistance = 3.4;
      controls.maxDistance = 9;
      controls.autoRotate = true;
      controls.autoRotateSpeed = 0.72;

      const keyLight = new THREE.DirectionalLight(0xffffff, 2.2);
      keyLight.position.set(3.5, 4.2, 4.5);
      scene.add(keyLight);

      const rimLight = new THREE.DirectionalLight(0x8edb35, 1.55);
      rimLight.position.set(-3.6, 2.6, -2.4);
      scene.add(rimLight);

      const fillLight = new THREE.HemisphereLight(0xa6ff5a, 0x080808, 1.15);
      scene.add(fillLight);

      const grid = new THREE.GridHelper(5.6, 18, 0x8edb35, 0x243315);
      grid.position.y = -1.35;
      grid.material.transparent = true;
      grid.material.opacity = 0.2;
      scene.add(grid);

      let modelRoot = null;
      let frameId = 0;
      let isVisible = false;

      function resizeProfileModel() {
        const rect = profileModelPanel.getBoundingClientRect();
        const width = Math.max(1, Math.floor(rect.width));
        const height = Math.max(1, Math.floor(rect.height));
        renderer.setSize(width, height, false);
        camera.aspect = width / height;
        camera.updateProjectionMatrix();
      }

      function frame() {
        if (!isVisible) {
          frameId = 0;
          return;
        }

        if (modelRoot) {
          modelRoot.rotation.y += 0.0022;
        }

        controls.update();
        renderer.render(scene, camera);
        frameId = window.requestAnimationFrame(frame);
      }

      function startProfileModel() {
        if (frameId) return;
        isVisible = true;
        resizeProfileModel();
        frame();
      }

      function stopProfileModel() {
        isVisible = false;
      }

      new GLTFLoader().load(
        '/models/lunar-lander.glb',
        (gltf) => {
          modelRoot = gltf.scene;
          const bounds = new THREE.Box3().setFromObject(modelRoot);
          const size = bounds.getSize(new THREE.Vector3());
          const center = bounds.getCenter(new THREE.Vector3());
          const maxAxis = Math.max(size.x, size.y, size.z) || 1;

          modelRoot.position.sub(center);
          modelRoot.scale.setScalar(2.45 / maxAxis);
          modelRoot.rotation.set(-0.08, 0.38, 0);

          modelRoot.traverse((node) => {
            if (!node.isMesh) return;
            node.castShadow = true;
            node.receiveShadow = true;
            node.geometry?.computeVertexNormals?.();

            const materials = Array.isArray(node.material) ? node.material : [node.material];
            materials.forEach((material) => {
              if (!material) return;
              material.flatShading = true;
              material.metalness = Math.min(material.metalness ?? 0.2, 0.48);
              material.roughness = Math.max(material.roughness ?? 0.42, 0.5);
              material.needsUpdate = true;
            });
          });

          scene.add(modelRoot);
          profileModelCanvas.dataset.modelReady = 'true';
          startProfileModel();
        },
        undefined,
        () => {
          profileModelCanvas.dataset.modelReady = 'error';
        }
      );

      const observer = new IntersectionObserver((entries) => {
        const entry = entries[0];
        if (entry?.isIntersecting) {
          startProfileModel();
        } else {
          stopProfileModel();
        }
      }, { threshold: 0.08 });

      observer.observe(profileModelPanel);
      window.addEventListener('resize', resizeProfileModel);
      resizeProfileModel();
    }
  </script>

