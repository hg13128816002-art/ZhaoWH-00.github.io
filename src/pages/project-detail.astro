        </header>

        <div class="meta-grid">
          <div>
            <div class="meta-item-label">TIMESTAMP</div>
            <div class="meta-item-value">2026</div>
          </div>
          <div>
            <div class="meta-item-label">CATEGORY</div>
            <div class="meta-item-value green">Serious Game / VR</div>
          </div>
