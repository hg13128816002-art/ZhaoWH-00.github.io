  <div class="preview-backdrop" aria-hidden="true"></div>

  <script is:inline>
    // @ts-nocheck
    const previewBackdrop = document.querySelector('.preview-backdrop');
    const previewTargets = document.querySelectorAll('[data-hover-preview]');
    let activePreview = null;
    let activeTarget = null;
    let activeAnimation = null;
    let closeTimer = null;
    let previewState = 'idle';

    const previewTiming = {
      duration: 560,
      easing: 'cubic-bezier(0.16, 1, 0.3, 1)',
      fill: 'forwards',
    };

    const getContainRect = (image, maxWidth, maxHeight) => {
      const ratio = image.naturalWidth && image.naturalHeight
        ? image.naturalWidth / image.naturalHeight
        : image.getBoundingClientRect().width / image.getBoundingClientRect().height;

      let width = maxWidth;
      let height = width / ratio;

      if (height > maxHeight) {
        height = maxHeight;
        width = height * ratio;
      }

      return {
        width,
        height,
        left: (window.innerWidth - width) / 2,
        top: (window.innerHeight - height) / 2,
      };
    };

    const applyPreviewRect = (image, rect, objectFit) => {
      image.style.left = `${rect.left}px`;
      image.style.top = `${rect.top}px`;
      image.style.width = `${rect.width}px`;
      image.style.height = `${rect.height}px`;
      image.style.objectFit = objectFit;
    };

    const rectFromElement = (element) => {
      const rect = element.getBoundingClientRect();
      return {
        left: rect.left,
        top: rect.top,
        width: rect.width,
        height: rect.height,
      };
    };

    const cancelActiveAnimationAtCurrentFrame = () => {
      if (!activePreview || !activeAnimation) return null;

      const currentRect = rectFromElement(activePreview);
      activeAnimation.cancel();
      activeAnimation = null;
      applyPreviewRect(activePreview, currentRect, activePreview.style.objectFit || 'contain');
      activePreview.style.transform = 'translate3d(0, 0, 0) scale(1, 1)';
      return currentRect;
    };

    const animatePreviewRect = (image, fromRect, toRect, options = {}) => {
      applyPreviewRect(image, toRect, options.toFit || image.style.objectFit || 'contain');
      image.style.transformOrigin = 'top left';

      const fromTransform = `translate3d(${fromRect.left - toRect.left}px, ${fromRect.top - toRect.top}px, 0) scale(${fromRect.width / toRect.width}, ${fromRect.height / toRect.height})`;

      const animation = image.animate(
        [
          {
            transform: fromTransform,
            opacity: options.fromOpacity ?? 1,
          },
          {
            transform: 'translate3d(0, 0, 0) scale(1, 1)',
            opacity: options.toOpacity ?? 1,
          },
        ],
        previewTiming
      );

      activeAnimation = animation;

      animation.finished
        .then(() => {
          if (activeAnimation !== animation || activePreview !== image) return;
          applyPreviewRect(image, toRect, options.toFit || image.style.objectFit || 'contain');
          image.style.transform = 'translate3d(0, 0, 0) scale(1, 1)';
          image.style.opacity = `${options.toOpacity ?? 1}`;
          activeAnimation = null;
          previewState = options.removeOnFinish ? 'idle' : options.state || previewState;

          if (options.removeOnFinish) {
            removePreview();
          }
        })
        .catch(() => {});

      return animation;
    };

    const removePreview = () => {
      if (activeAnimation) {
        activeAnimation.cancel();
        activeAnimation = null;
      }

      if (!activePreview) return;
      activePreview.remove();
      activePreview = null;
      activeTarget = null;
      previewState = 'idle';
      previewBackdrop.classList.remove('active');
    };

    const showPreview = (event) => {
      const image = event.currentTarget;
      const sourceRect = image.getBoundingClientRect();
      const targetRect = getContainRect(image, window.innerWidth * 0.78, window.innerHeight * 0.78);

      window.clearTimeout(closeTimer);

      if (activePreview && activeTarget === image && previewState !== 'closing') {
        return;
      }

      removePreview();

      const clone = image.cloneNode(false);
      activePreview = clone;
      activeTarget = image;

      clone.removeAttribute('data-hover-preview');
      clone.style.position = 'fixed';
      clone.style.zIndex = '80';
      clone.style.margin = '0';
      clone.style.border = '1px solid rgba(142, 219, 53, 0.48)';
      clone.style.background = '#050505';
      clone.style.boxShadow = '0 0 40px rgba(0, 0, 0, 0.85), 0 0 32px rgba(142, 219, 53, 0.14)';
      clone.style.pointerEvents = 'none';
      clone.style.transform = 'translateZ(0)';
      clone.style.transformOrigin = 'top left';
      clone.style.transition = 'none';
      clone.style.animation = 'none';
      clone.style.filter = 'none';
      clone.style.willChange = 'transform, opacity';
      clone.style.opacity = '0.98';

      applyPreviewRect(clone, sourceRect, getComputedStyle(image).objectFit || 'cover');
      document.body.appendChild(clone);
      previewBackdrop.classList.add('active');
      previewState = 'opening';
      animatePreviewRect(clone, sourceRect, targetRect, {
        fromOpacity: 0.98,
        toOpacity: 1,
        toFit: 'contain',
        state: 'open',
      });
    };

    const hidePreview = (event) => {
      if (!activePreview || event.currentTarget !== activeTarget) return;
      if (previewState === 'closing') return;

      const sourceRect = activeTarget.getBoundingClientRect();
      const clone = activePreview;
      const currentRect = cancelActiveAnimationAtCurrentFrame() || rectFromElement(clone);

      previewBackdrop.classList.remove('active');
      previewState = 'closing';
      animatePreviewRect(clone, currentRect, sourceRect, {
        fromOpacity: Number.parseFloat(getComputedStyle(clone).opacity) || 1,
        toOpacity: 0,
        toFit: getComputedStyle(activeTarget).objectFit || 'cover',
        removeOnFinish: true,
        state: 'idle',
      });
    };

    previewTargets.forEach((image) => {
      image.addEventListener('mouseenter', showPreview);
      image.addEventListener('mouseleave', hidePreview);
      image.addEventListener('focus', showPreview);
      image.addEventListener('blur', hidePreview);
    });
  </script>

