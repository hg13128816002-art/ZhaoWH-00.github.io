            <div class="visual-meta-value">ART THERAPY</div>
          </div>
          <div class="visual-meta-item">
            <div class="visual-meta-label">MEDIUM</div>
            <div class="visual-meta-value">APPLICATION PROGRAM</div>
          </div>
          <div class="visual-meta-item">
            <div class="visual-meta-label">MOOD</div>
            <div class="visual-meta-value">NOSTALGIA / ASH</div>
          </div>
          <div class="visual-meta-item">
            <div class="visual-meta-label">LOCATION</div>
            <div class="visual-meta-value">BEIJING</div>
