---
// src/pages/project-detail.astro
// 修复版：移除 Tailwind CDN，使用原生 CSS
---

<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ARCHIVE // NEVER_EXTINGUISHED</title>
  <link rel="preload" href="/fonts/NotoSansSC-Regular.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/fonts/NotoSansSC-Bold.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/fonts/NotoSansSC-Black.woff2" as="font" type="font/woff2" crossorigin>
  <script src="/scripts/font-loader.js" is:inline></script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@100;300;400;700;800&display=swap');

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Noto Sans SC Local', 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace;
      background-color: #050505;
      color: #a3a3a3;
      margin: 0;
      overflow-x: hidden;
      overflow-y: auto;
      user-select: none;
    }

    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: #050505; }
    ::-webkit-scrollbar-thumb { background: #333; }
    ::-webkit-scrollbar-thumb:hover { background: #8EDB35; }

    .grid-bg {
      position: fixed;
      inset: 0;
      background-size: 40px 40px;
      background-image: linear-gradient(to right, rgba(255, 255, 255, 0.02) 1px, transparent 1px),
                        linear-gradient(to bottom, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
      pointer-events: none;
      z-index: 0;
    }

    .home-btn {
      position: fixed;
      top: 2rem;
      right: 2rem;
      z-index: 50;
      width: 3rem;
      height: 3rem;
      border-radius: 50%;
      border: 1px solid rgba(142, 219, 53, 0.3);
      background: rgba(10, 10, 10, 0.8);
      backdrop-filter: blur(8px);
      display: flex;
      align-items: center;
      justify-content: center;
      color: #8EDB35;
      transition: all 0.3s;
      cursor: pointer;
      box-shadow: 0 0 15px rgba(142, 219, 53, 0.1);
      text-decoration: none;
    }

    .home-btn:hover {
      background: #8EDB35;
      color: black;
      box-shadow: 0 0 25px rgba(142, 219, 53, 0.5);
    }

    .home-btn svg {
      transition: transform 0.3s;
    }

    .home-btn:hover svg {
      transform: translateX(-0.25rem);
    }

    .project-stack {
      position: relative;
      z-index: 1;
      width: 100%;
    }

    .project-entry {
      position: relative;
      width: 100%;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    .left-panel {
      position: relative;
      width: 100%;
      min-height: 50vh;
      border-bottom: 1px solid #171717;
      z-index: 10;
      background: #020202;
      padding: 1.5rem;
      display: flex;
      flex-direction: column;
    }

    .left-panel-label {
      position: absolute;
      top: 1.5rem;
      left: 1.5rem;
      color: #404040;
      font-size: 10px;
      letter-spacing: 0.4em;
      z-index: 30;
    }

    .img-container {
      position: relative;
      width: 100%;
      aspect-ratio: 16 / 9;
      flex: none;
      margin-top: 2rem;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      border: 1px solid #171717;
      background: #050505;
      cursor: zoom-in;
    }

    .corner-tl {
      position: absolute;
      top: 0;
      left: 0;
      width: 1rem;
      height: 1rem;
      border-top: 1px solid #8EDB35;
      border-left: 1px solid #8EDB35;
      z-index: 20;
      transition: all 0.3s;
    }

    .corner-br {
      position: absolute;
      bottom: 0;
      right: 0;
      width: 1rem;
      height: 1rem;
      border-bottom: 1px solid #8EDB35;
      border-right: 1px solid #8EDB35;
      z-index: 20;
      transition: all 0.3s;
    }

    .img-container:hover .corner-tl,
    .img-container:hover .corner-br {
      width: 2rem;
      height: 2rem;
    }

    .main-img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      filter: grayscale(0.2);
      transition: all 0.7s;
      display: block;
    }

    .img-container:hover .main-img {
      filter: grayscale(0);
    }

    .visual-caption {
      color: #525252;
      font-size: 10px;
      letter-spacing: 0.2em;
      line-height: 1.7;
      margin-top: 1rem;
      padding-bottom: 1.25rem;
      border-bottom: 1px solid #171717;
    }

    .visual-meta {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
      margin-top: 1.5rem;
    }

    .visual-meta-item {
      min-width: 0;
    }

    .visual-meta-label {
      color: #404040;
      font-size: 9px;
      letter-spacing: 0.24em;
      margin-bottom: 0.35rem;
    }

    .visual-meta-value {
      color: #d4d4d4;
      font-size: 12px;
      line-height: 1.5;
      overflow-wrap: break-word;
    }

    .thumb-strip {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.75rem;
      margin-top: 2rem;
    }

    .thumb-item {
      position: relative;
      aspect-ratio: 4 / 3;
      border: 1px solid #171717;
      background: #0a0a0a;
      overflow: hidden;
      cursor: zoom-in;
    }

    .thumb-strip-wide .thumb-item {
      aspect-ratio: 16 / 9;
    }

    .project-entry-liminal .thumb-strip {
      margin-top: 5.55rem;
    }

    .project-entry-never .thumb-item {
      aspect-ratio: 16 / 10;
    }

    .project-entry-never .thumb-strip {
      margin-top: 1.85rem;
    }

    .thumb-item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      filter: grayscale(0.55);
      transition: filter 0.35s, transform 0.35s;
    }

    .thumb-item:hover img {
      filter: grayscale(0);
      transform: scale(1.04);
    }

    .thumb-index {
      position: absolute;
      left: 0.5rem;
      bottom: 0.45rem;
      color: #8EDB35;
      font-size: 9px;
      letter-spacing: 0.18em;
      text-shadow: 0 0 10px #050505;
    }

    .archive-rail {
      margin-top: auto;
      padding-top: 2rem;
    }

    .archive-rail-line {
      height: 1px;
      background: linear-gradient(90deg, #8EDB35, #171717 45%, transparent);
      margin-bottom: 1rem;
    }

    .archive-rail-text {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      color: #404040;
      font-size: 10px;
      letter-spacing: 0.24em;
    }

    .preview-backdrop {
      position: fixed;
      inset: 0;
      z-index: 79;
      pointer-events: none;
      background: rgba(5, 5, 5, 0);
      opacity: 0;
      transition: opacity 0.28s ease, background 0.28s ease;
    }

    .preview-backdrop.active {
      opacity: 1;
      background: rgba(5, 5, 5, 0.68);
    }

    .right-panel {
      width: 100%;
      min-height: 50vh;
      z-index: 20;
      position: relative;
      background: #050505;
      padding: 3.5rem 1.5rem 1.5rem;
      display: flex;
      flex-direction: column;
    }

    .file-label {
      color: #8EDB35;
      font-size: 10px;
      letter-spacing: 0.4em;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      margin-bottom: 1.5rem;
    }

    .pulse-dot {
      width: 0.375rem;
      height: 0.375rem;
      background: #8EDB35;
      animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.5; }
    }

    .title-main {
      color: white;
      font-size: 2.25rem;
      font-weight: 800;
      letter-spacing: -0.025em;
      text-transform: uppercase;
      line-height: 1.1;
      margin-bottom: 0.5rem;
      word-break: break-word;
    }

    .title-sub {
      color: #737373;
      font-size: 0.875rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
    }

    .meta-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.5rem;
      border-top: 1px solid #171717;
      border-bottom: 1px solid #171717;
      padding: 1.5rem 0;
      margin: 2rem 0;
      background: rgba(5, 5, 5, 0.3);
    }

    .meta-item-label {
      color: #525252;
      font-size: 9px;
      letter-spacing: 0.3em;
      margin-bottom: 0.375rem;
    }

    .meta-item-value {
      color: #e5e5e5;
      font-size: 0.875rem;
    }

    .meta-item-value.green {
      color: #8EDB35;
    }

    .section {
      margin-bottom: 3rem;
    }

    .section-title {
      color: white;
      font-size: 0.875rem;
      letter-spacing: 0.2em;
      font-weight: 700;
      border-left: 2px solid #8EDB35;
      padding-left: 0.75rem;
      margin-bottom: 1rem;
    }

    .section-text {
      font-size: 14px;
      line-height: 1.75;
      color: #a3a3a3;
      text-align: left;
      word-wrap: break-word;
      overflow-wrap: break-word;
    }

    .footer {
      margin-top: auto;
      padding-top: 4rem;
      padding-bottom: 2rem;
      color: #262626;
      font-size: 10px;
      letter-spacing: 0.3em;
      border-top: 1px solid #171717;
    }

    /* 桌面端响应式 */
    @media (min-width: 768px) {
      .project-entry {
        display: flex;
        flex-direction: row;
        align-items: stretch;
      }

      .left-panel {
        position: relative;
        width: 40%;
        height: auto;
        min-height: 100vh;
        border-bottom: none;
        border-right: 1px solid #171717;
        padding: 3rem;
        flex-shrink: 0;
      }

      .main-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .right-panel {
        width: 60%;
        margin-left: 0;
        margin-top: 0;
        min-height: 100vh;
        padding: 5rem 3rem 3rem;
      }

      .title-main {
        font-size: 3.5rem;
      }

      .title-sub {
        font-size: 1rem;
      }


      .section-text {
        font-size: 15px;
        line-height: 1.8;
        text-align: left;
      }

    }

    @media (min-width: 1024px) {
      .left-panel {
        padding: 4rem;
      }

      .right-panel {
        padding: 6rem 5rem 4rem;
      }

      .title-main {
        font-size: 4.5rem;
      }

      .title-sub {
        font-size: 1.125rem;
      }

      .meta-grid {
        grid-template-columns: repeat(3, 1fr);
      }

      .meta-full-width {
        grid-column: span 3;
      }
    }

    @media (min-width: 1280px) {
      .right-panel {
        padding: 6rem 6rem 5rem;
      }
    }

  </style>
</head>
<body>

  <div class="grid-bg"></div>

  <a href="/" class="home-btn">
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="square" stroke-linejoin="miter" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
    </svg>
  </a>

  <main class="project-stack">
    <article class="project-entry project-entry-never">
      <div class="left-panel">
