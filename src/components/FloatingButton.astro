---
// src/components/FloatingButton.astro
// 全局悬浮返回球：直达导航枢纽，带有极其细腻的玻璃质感与先锋绿呼吸灯
---

<div class="fixed bottom-8 right-8 z-[9999] pointer-events-auto select-none">
  <a 
    href="/hub" 
    class="group flex items-center gap-3 p-3 bg-[#0a0a0a]/80 backdrop-blur-md border border-neutral-800 hover:border-[#8EDB35]/50 transition-all duration-300 rounded-full shadow-2xl"
  >
    <div class="relative flex items-center justify-center w-5 h-5">
      <div class="absolute inset-0 bg-[#8EDB35] rounded-full opacity-50 group-hover:opacity-100 group-hover:scale-150 transition-all duration-300 blur-[5px]"></div>
      <div class="relative w-2.5 h-2.5 bg-[#8EDB35] rounded-full shadow-[0_0_10px_#8EDB35] group-hover:scale-125 transition-transform duration-300"></div>
    </div>

    <span class="max-w-0 overflow-hidden group-hover:max-w-xs transition-all duration-300 ease-in-out whitespace-nowrap text-[#8EDB35] font-mono text-xs font-bold tracking-widest group-hover:px-1">
      // NAV_HUB
    </span>
  </a>
</div>