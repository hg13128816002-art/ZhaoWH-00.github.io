---
// src/components/LiquidNavHub.astro
// 终极完美版：已修复 Canvas 透明度叠加黑屏 Bug，视频通透透出！
---

<div id="liquid-nav-root" class="relative w-screen h-screen bg-[#0a0a0a] overflow-hidden font-mono select-none">
  
  <video 
    id="bg-video"
    src="/showcase-bg.mp4" 
    autoplay 
    loop 
    muted 
    playsinline 
    class="absolute inset-0 w-full h-full object-cover z-0 pointer-events-none"
  ></video>

  <div class="absolute top-8 right-8 text-right pointer-events-none z-20">
    <div class="text-[#8EDB35] text-[10px] tracking-[0.4em] font-bold">SECTION // 02_NAVIGATION_HUB</div>
    <div class="text-neutral-500 text-[10px] mt-1 tracking-widest">BACKGROUND: DYNAMIC_VIDEO</div>
  </div>

  <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 pointer-events-none z-20 text-neutral-400 text-xs tracking-widest">
    [ MOVE CURSOR TO CAPTURE & CLICK ]
  </div>

  <canvas id="liquid-canvas" class="absolute inset-0 block w-full h-full z-10 cursor-none"></canvas>

</div>

<style>
  /* 使用自托管中文黑体，并让 canvas 文本优先使用 Noto Sans SC Local */
</style>

<script>
  const canvas = document.getElementById('liquid-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;
  canvas.style.visibility = 'hidden';
  const notoFontPromise = window.fontsReadyPromise || (document.fonts && document.fonts.load ? document.fonts.load('20px "Noto Sans SC Local"') : Promise.resolve());

  // 强制点火引擎
  const bgVideo = document.getElementById('bg-video') as HTMLVideoElement;
  if (bgVideo) {
    bgVideo.muted = true; 
    const playPromise = bgVideo.play();
    if (playPromise !== undefined) {
      playPromise.catch(() => {
        window.addEventListener('mousemove', () => {
          bgVideo.play().catch(() => {});
        }, { once: true });
      });
    }
  }

  // 全局尺寸同步
  let width = window.visualViewport?.width || window.innerWidth;
  let height = window.visualViewport?.height || window.innerHeight;
  let dpr = Math.min(window.devicePixelRatio || 1, 2);
  function resize() {
    width = window.visualViewport?.width || window.innerWidth;
    height = window.visualViewport?.height || window.innerHeight;
    dpr = Math.min(window.devicePixelRatio || 1, 2);
    canvas.width = Math.floor(width * dpr);
    canvas.height = Math.floor(height * dpr);
    canvas.style.width = `${width}px`;
    canvas.style.height = `${height}px`;
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    layoutPills();
  }

  const GREEN = '#8EDB35';
  
  const FONT_STACK = '"Space Mono", "PingFang SC", "Microsoft YaHei", "Noto Sans SC", sans-serif';
  const templates = [
    { text: "Watch the videos of the works / 视频", mobileText: "VIDEOS / 视频", href: "/omni" },
    { text: "View the pictures of the works / 图片", mobileText: "PICTURES / 图片", href: "/dual" },
    { text: "Get to know me / 关于我", mobileText: "ABOUT / 关于我", href: "/about" },
    { text: "Contact me / 联系我", mobileText: "CONTACT / 联系我", href: "/contact" },
    { text: "Explore project details / 项目详情", mobileText: "PROJECTS / 项目", href: "/project-detail" }
  ];

  interface Pill {
    id: number;
    text: string;
    href: string;
    mobileText: string;
    baseX: number;
    baseY: number;
    x: number;
    y: number;
    w: number;
    h: number;
    fontSize: number;
    phase: number;
    locked: boolean;
  }

  const pills: Pill[] = [];
  const items = templates;

  function isMobileLayout() {
    return width < 768 || window.matchMedia('(pointer: coarse)').matches;
  }

  function clamp(value: number, min: number, max: number) {
    return Math.min(max, Math.max(min, value));
  }

  function getPillText(pill: Pill | typeof templates[number]) {
    return isMobileLayout() ? pill.mobileText : pill.text;
  }

  function updatePillMetrics() {
    const mobile = isMobileLayout();
    pills.forEach((pill) => {
      pill.fontSize = mobile ? clamp(width * 0.038, 13, 16) : 20;
      ctx.font = `bold ${pill.fontSize}px ${FONT_STACK}`;

      const labelWidth = ctx.measureText(getPillText(pill)).width;
      const mobileMaxWidth = Math.max(160, width - 32);
      const mobileMinWidth = Math.min(220, mobileMaxWidth);
      pill.w = mobile
        ? Math.min(Math.max(labelWidth + 48, mobileMinWidth), Math.min(360, mobileMaxWidth))
        : Math.min(labelWidth + 80, width - 48);
      pill.h = mobile
        ? clamp(height * 0.07, 48, 58)
        : 60;
    });
  }

  function getPillTargets() {
    if (isMobileLayout()) {
      const centerX = width / 2;
      const topSafe = clamp(height * 0.18, 112, 156);
      const bottomSafe = 92;
      const availableHeight = Math.max(280, height - topSafe - bottomSafe);
      const gap = items.length > 1 ? availableHeight / (items.length - 1) : 0;

      return items.map((_, index) => ({
        cx: centerX,
        cy: topSafe + index * gap,
      }));
    }

    const centerX = width / 2;
    const centerY = height / 2;
    const radiusX = Math.min(width * 0.28, 430);
    const radiusY = Math.min(height * 0.24, 230);

    return [
      { cx: centerX, cy: centerY },
      { cx: centerX - radiusX, cy: centerY - radiusY },
      { cx: centerX + radiusX, cy: centerY - radiusY },
      { cx: centerX - radiusX, cy: centerY + radiusY },
      { cx: centerX + radiusX, cy: centerY + radiusY },
    ];
  }

  function layoutPills() {
    if (!pills.length) return;
    updatePillMetrics();

    const targets = getPillTargets();
    const mobile = isMobileLayout();
    const sideInset = mobile ? 16 : 24;
    const topInset = mobile ? 104 : 72;
    const bottomInset = mobile ? 32 : 56;

    pills.forEach((pill, index) => {
      const target = targets[index] || targets[0];
      pill.baseX = Math.max(sideInset, Math.min(target.cx - pill.w / 2, width - pill.w - sideInset));
      pill.baseY = Math.max(topInset, Math.min(target.cy - pill.h / 2, height - pill.h - bottomInset));
      pill.x = pill.baseX;
      pill.y = pill.baseY;
    });
  }

  function createPills() {
    items.forEach((item, index) => {
      pills.push({
        id: index,
        text: item.text,
        mobileText: item.mobileText,
        href: item.href,
        baseX: 0,
        baseY: 0,
        x: 0,
        y: 0,
        w: 0,
        h: 0,
        fontSize: 20,
        phase: index * 1.35,
        locked: false
      });
    });

    layoutPills();
  }

  window.addEventListener('resize', resize);
  window.visualViewport?.addEventListener('resize', resize);
  resize();

  const mouse = { x: width / 2, y: height / 2 };
  let bubbleX = width / 2;
  let bubbleY = height / 2;
  let lockedPill: Pill | null = null;
  
  window.addEventListener('mousemove', (e) => {
    mouse.x = e.clientX;
    mouse.y = e.clientY;
  });

  canvas.addEventListener('pointerup', (event) => {
    const hitPill = pills.find((pill) => (
      event.clientX >= pill.x
      && event.clientX <= pill.x + pill.w
      && event.clientY >= pill.y
      && event.clientY <= pill.y + pill.h
    ));

    if (hitPill) {
      navigateTo(hitPill.href);
    } else if (lockedPill) {
      navigateTo(lockedPill.href);
    }
  });

  function navigateTo(href: string) {
    const triggerPureTransition = (window as any).triggerPureTransition;
    if (typeof triggerPureTransition === 'function') {
      triggerPureTransition(href);
    } else {
      window.location.href = href;
    }
  }

  const LOCK_DIST = 120;   
  const BREAK_DIST = 220; 

  function animate() {
    const time = performance.now() * 0.001;
    // 👇 核心洗刷修复：先擦除，再画透明底，永保 75% 恒定透视率！
    ctx.clearRect(0, 0, width, height);
    ctx.fillStyle = 'rgba(10, 10, 10, 0.75)';
    ctx.fillRect(0, 0, width, height);

    if (!lockedPill) {
      bubbleX += (mouse.x - bubbleX) * 0.15;
      bubbleY += (mouse.y - bubbleY) * 0.15;

      pills.forEach(p => {
        p.x = p.baseX + Math.sin(time * 1.1 + p.phase) * 3;
        p.y = p.baseY + Math.cos(time * 1.05 + p.phase) * 2;

        const cx = p.x + p.w / 2;
        const cy = p.y + p.h / 2;
        const dist = Math.hypot(mouse.x - cx, mouse.y - cy);
        if (dist < LOCK_DIST) {
          lockedPill = p;
          p.locked = true;
        }
      });
    } else {
      const targetCx = lockedPill.x + lockedPill.w / 2;
      const targetCy = lockedPill.y + lockedPill.h / 2;

      const stretchX = (mouse.x - targetCx) * 0.28;
      const stretchY = (mouse.y - targetCy) * 0.28;

      bubbleX += (targetCx + stretchX - bubbleX) * 0.2;
      bubbleY += (targetCy + stretchY - bubbleY) * 0.2;

      const distToCenter = Math.hypot(mouse.x - targetCx, mouse.y - targetCy);
      if (distToCenter > BREAK_DIST) {
        lockedPill.locked = false;
        lockedPill = null;
      }
    }

    ctx.save();
    ctx.fillStyle = GREEN;
    if (!lockedPill) {
      ctx.beginPath();
      ctx.arc(bubbleX, bubbleY, 65, 0, Math.PI * 2);
      ctx.fill();
    } else {
      const padding = 24;
      const bx = lockedPill.x - padding;
      const by = lockedPill.y - padding;
      const bw = lockedPill.w + padding * 2;
      const bh = lockedPill.h + padding * 2;
      const radius = 32;

      ctx.beginPath();
      ctx.roundRect(
        bx + (bubbleX - (lockedPill.x + lockedPill.w/2)) * 0.3, 
        by + (bubbleY - (lockedPill.y + lockedPill.h/2)) * 0.3, 
        bw, bh, radius
      );
      ctx.fill();
    }
    ctx.restore();

    ctx.textBaseline = 'middle';
    ctx.textAlign = 'center';

    pills.forEach(p => {
      if (!p.locked) {
        p.x = p.baseX + Math.sin(time * 1.1 + p.phase) * 3;
        p.y = p.baseY + Math.cos(time * 1.05 + p.phase) * 2;
      }

      ctx.save();
      const cx = p.x + p.w / 2;
      const cy = p.y + p.h / 2;
      const breath = 0.5 + Math.sin(time * 1.6 + p.phase) * 0.5;

      if (p.locked) {
        ctx.fillStyle = '#000000';
        ctx.font = `900 ${p.fontSize}px ${FONT_STACK}`;
        ctx.fillText(getPillText(p), cx, cy);
      } else {
        const radius = isMobileLayout() ? 14 : 18;
        ctx.strokeStyle = `rgba(142, 219, 53, ${0.45 + breath * 0.45})`;
        ctx.lineWidth = 1.25 + breath * 1.25;
        ctx.shadowColor = GREEN;
        ctx.shadowBlur = 12 + breath * 22;
        ctx.beginPath();
        ctx.roundRect(p.x + 0.5, p.y + 0.5, p.w - 1, p.h - 1, radius);
        ctx.stroke();
        ctx.shadowBlur = 0;

        ctx.fillStyle = `rgba(229, 229, 229, ${0.82 + breath * 0.18})`;
        ctx.font = `bold ${p.fontSize}px ${FONT_STACK}`;
        ctx.fillText(getPillText(p), cx, cy);
      }
      ctx.restore();
    });

    if (!lockedPill) {
      ctx.fillStyle = '#0a0a0a';
      ctx.beginPath();
      ctx.arc(bubbleX, bubbleY, 4, 0, Math.PI * 2);
      ctx.fill();
    }

    requestAnimationFrame(animate);
  }

  notoFontPromise.then(() => {
    createPills();
    canvas.style.visibility = 'visible';
    animate();
  }).catch(() => {
    createPills();
    canvas.style.visibility = 'visible';
    animate();
  });
</script>
