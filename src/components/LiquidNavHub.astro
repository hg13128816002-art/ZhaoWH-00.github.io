---
// src/components/LiquidNavHub.astro
// 终极完美版：已修复 Canvas 透明度叠加黑屏 Bug，视频通透透出！
---

<div id="liquid-nav-root" class="relative w-screen h-screen bg-[#0a0a0a] overflow-hidden font-mono select-none">
  
  <video 
    id="bg-video"
    src="/showcase-bg.mp4" 
    autoplay 
    loop 
    muted 
    playsinline 
    class="absolute inset-0 w-full h-full object-cover z-0 pointer-events-none"
  ></video>

  <div class="absolute top-8 right-8 text-right pointer-events-none z-20">
    <div class="text-[#8EDB35] text-[10px] tracking-[0.4em] font-bold">SECTION // 02_NAVIGATION_HUB</div>
    <div class="text-neutral-500 text-[10px] mt-1 tracking-widest">BACKGROUND: DYNAMIC_VIDEO</div>
  </div>

  <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 pointer-events-none z-20 text-neutral-400 text-xs tracking-widest">
    [ MOVE CURSOR TO CAPTURE & CLICK ]
  </div>

  <canvas id="liquid-canvas" class="absolute inset-0 block w-full h-full z-10 cursor-none"></canvas>

</div>

<style>
  /* 使用自托管中文黑体，并让 canvas 文本优先使用 Noto Sans SC Local */
</style>

<script>
  const canvas = document.getElementById('liquid-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;
  canvas.style.visibility = 'hidden';
  const notoFontPromise = window.fontsReadyPromise || (document.fonts && document.fonts.load ? document.fonts.load('20px "Noto Sans SC Local"') : Promise.resolve());

  // 强制点火引擎
  const bgVideo = document.getElementById('bg-video') as HTMLVideoElement;
  if (bgVideo) {
    bgVideo.muted = true; 
    const playPromise = bgVideo.play();
    if (playPromise !== undefined) {
      playPromise.catch(() => {
        window.addEventListener('mousemove', () => {
          bgVideo.play().catch(() => {});
        }, { once: true });
      });
    }
  }

  // 全局尺寸同步
  let width = window.innerWidth;
  let height = window.innerHeight;
  let dpr = Math.min(window.devicePixelRatio || 1, 2);
  function resize() {
    width = window.innerWidth;
    height = window.innerHeight;
    dpr = Math.min(window.devicePixelRatio || 1, 2);
    canvas.width = Math.floor(width * dpr);
    canvas.height = Math.floor(height * dpr);
    canvas.style.width = `${width}px`;
    canvas.style.height = `${height}px`;
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    layoutPills();
  }

  const GREEN = '#8EDB35';
  
  const FONT_STACK = '"Space Mono", "PingFang SC", "Microsoft YaHei", "Noto Sans SC", sans-serif';
  const templates = [
    { text: "Watch the videos of the works / 视频", href: "/omni" },
    { text: "View the pictures of the works / 图片", href: "/dual" },
    { text: "Get to know me / 关于我", href: "/about" },
    { text: "Contact me / 联系我", href: "/contact" },
    { text: "Explore project details / 项目详情", href: "/project-detail" }
  ];

  interface Pill {
    id: number;
    text: string;
    href: string;
    baseX: number;
    baseY: number;
    x: number;
    y: number;
    w: number;
    h: number;
    phase: number;
    locked: boolean;
  }

  const pills: Pill[] = [];
  const items = templates;

  function getPillTargets() {
    if (width < 768) {
      const centerX = width / 2;
      const startY = height * 0.22;
      const gap = Math.min(96, Math.max(72, height * 0.105));
      return items.map((_, index) => ({
        cx: centerX,
        cy: startY + index * gap,
      }));
    }

    const centerX = width / 2;
    const centerY = height / 2;
    const radiusX = Math.min(width * 0.28, 430);
    const radiusY = Math.min(height * 0.24, 230);

    return [
      { cx: centerX, cy: centerY },
      { cx: centerX - radiusX, cy: centerY - radiusY },
      { cx: centerX + radiusX, cy: centerY - radiusY },
      { cx: centerX - radiusX, cy: centerY + radiusY },
      { cx: centerX + radiusX, cy: centerY + radiusY },
    ];
  }

  function layoutPills() {
    if (!pills.length) return;
    const targets = getPillTargets();
    pills.forEach((pill, index) => {
      const target = targets[index] || targets[0];
      pill.baseX = Math.max(24, Math.min(target.cx - pill.w / 2, width - pill.w - 24));
      pill.baseY = Math.max(72, Math.min(target.cy - pill.h / 2, height - pill.h - 56));
      pill.x = pill.baseX;
      pill.y = pill.baseY;
    });
  }

  function createPills() {
    ctx.font = 'bold 20px "Space Mono"';
    ctx.font = `bold 20px ${FONT_STACK}`;
    items.forEach((item, index) => {
      const textWidth = ctx.measureText(item.text).width;
      const w = Math.min(textWidth + 80, width - 48);
      const h = 60;

      pills.push({
        id: index,
        text: item.text,
        href: item.href,
        baseX: 0,
        baseY: 0,
        x: 0,
        y: 0,
        w,
        h,
        phase: index * 1.35,
        locked: false
      });
    });

    layoutPills();
  }

  window.addEventListener('resize', resize);
  resize();

  const mouse = { x: width / 2, y: height / 2 };
  let bubbleX = width / 2;
  let bubbleY = height / 2;
  let lockedPill: Pill | null = null;
  
  window.addEventListener('mousemove', (e) => {
    mouse.x = e.clientX;
    mouse.y = e.clientY;
  });

  canvas.addEventListener('click', () => {
  if (lockedPill) {
    // 呼叫咱们的高阶矩阵切片幕布降下！
    const triggerPureTransition = (window as any).triggerPureTransition;
    if (typeof triggerPureTransition === 'function') {
      triggerPureTransition(lockedPill.href);
    } else {
      // 极度安全的底层兜底
      window.location.href = lockedPill.href;
    }
  }
});

  const LOCK_DIST = 120;   
  const BREAK_DIST = 220; 

  function animate() {
    const time = performance.now() * 0.001;
    // 👇 核心洗刷修复：先擦除，再画透明底，永保 75% 恒定透视率！
    ctx.clearRect(0, 0, width, height);
    ctx.fillStyle = 'rgba(10, 10, 10, 0.75)';
    ctx.fillRect(0, 0, width, height);

    if (!lockedPill) {
      bubbleX += (mouse.x - bubbleX) * 0.15;
      bubbleY += (mouse.y - bubbleY) * 0.15;

      pills.forEach(p => {
        p.x = p.baseX + Math.sin(time * 1.1 + p.phase) * 3;
        p.y = p.baseY + Math.cos(time * 1.05 + p.phase) * 2;

        const cx = p.x + p.w / 2;
        const cy = p.y + p.h / 2;
        const dist = Math.hypot(mouse.x - cx, mouse.y - cy);
        if (dist < LOCK_DIST) {
          lockedPill = p;
          p.locked = true;
        }
      });
    } else {
      const targetCx = lockedPill.x + lockedPill.w / 2;
      const targetCy = lockedPill.y + lockedPill.h / 2;

      const stretchX = (mouse.x - targetCx) * 0.28;
      const stretchY = (mouse.y - targetCy) * 0.28;

      bubbleX += (targetCx + stretchX - bubbleX) * 0.2;
      bubbleY += (targetCy + stretchY - bubbleY) * 0.2;

      const distToCenter = Math.hypot(mouse.x - targetCx, mouse.y - targetCy);
      if (distToCenter > BREAK_DIST) {
        lockedPill.locked = false;
        lockedPill = null;
      }
    }

    ctx.save();
    ctx.fillStyle = GREEN;
    if (!lockedPill) {
      ctx.beginPath();
      ctx.arc(bubbleX, bubbleY, 65, 0, Math.PI * 2);
      ctx.fill();
    } else {
      const padding = 24;
      const bx = lockedPill.x - padding;
      const by = lockedPill.y - padding;
      const bw = lockedPill.w + padding * 2;
      const bh = lockedPill.h + padding * 2;
      const radius = 32;

      ctx.beginPath();
      ctx.roundRect(
        bx + (bubbleX - (lockedPill.x + lockedPill.w/2)) * 0.3, 
        by + (bubbleY - (lockedPill.y + lockedPill.h/2)) * 0.3, 
        bw, bh, radius
      );
      ctx.fill();
    }
    ctx.restore();

    ctx.textBaseline = 'middle';
    ctx.textAlign = 'center';

    pills.forEach(p => {
      if (!p.locked) {
        p.x = p.baseX + Math.sin(time * 1.1 + p.phase) * 3;
        p.y = p.baseY + Math.cos(time * 1.05 + p.phase) * 2;
      }

      ctx.save();
      const cx = p.x + p.w / 2;
      const cy = p.y + p.h / 2;
      const breath = 0.5 + Math.sin(time * 1.6 + p.phase) * 0.5;

      if (p.locked) {
        ctx.fillStyle = '#000000';
        ctx.font = `900 20px ${FONT_STACK}`;
        ctx.fillText(p.text, cx, cy);
      } else {
        const radius = 18;
        ctx.strokeStyle = `rgba(142, 219, 53, ${0.45 + breath * 0.45})`;
        ctx.lineWidth = 1.25 + breath * 1.25;
        ctx.shadowColor = GREEN;
        ctx.shadowBlur = 12 + breath * 22;
        ctx.beginPath();
        ctx.roundRect(p.x + 0.5, p.y + 0.5, p.w - 1, p.h - 1, radius);
        ctx.stroke();
        ctx.shadowBlur = 0;

        ctx.fillStyle = `rgba(229, 229, 229, ${0.82 + breath * 0.18})`;
        ctx.font = `bold 20px ${FONT_STACK}`;
        ctx.fillText(p.text, cx, cy);
      }
      ctx.restore();
    });

    if (!lockedPill) {
      ctx.fillStyle = '#0a0a0a';
      ctx.beginPath();
      ctx.arc(bubbleX, bubbleY, 4, 0, Math.PI * 2);
      ctx.fill();
    }

    requestAnimationFrame(animate);
  }

  notoFontPromise.then(() => {
    createPills();
    canvas.style.visibility = 'visible';
    animate();
  }).catch(() => {
    createPills();
    canvas.style.visibility = 'visible';
    animate();
  });
</script>
