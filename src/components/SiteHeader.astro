---
// src/components/SiteHeader.astro
// 全站常驻导航：参考作品集站点的直观顶部导航结构。

const normalizePath = (path: string) => {
  if (path === '/') return '/';
  return path.replace(/\/$/, '');
};

const currentPath = normalizePath(Astro.url.pathname);
const navItems = [
  { href: '/', label: 'HOME', match: '/' },
  { href: '/project-detail', label: 'PROJECTS', match: '/project-detail' },
  { href: '/omni', label: 'VIDEOS', match: '/omni' },
  { href: '/dual', label: 'PICTURES', match: '/dual' },
  { href: '/profile', label: 'PROFILE', match: '/profile' },
  { href: '/contact', label: 'CONTACT', match: '/contact' },
];

const isActive = (item: typeof navItems[number]) => {
  return currentPath === item.match;
};

const shouldStayVisibleAtTop = currentPath === '/omni' || currentPath === '/dual' || currentPath === '/contact';
const shouldHideAtTop = !shouldStayVisibleAtTop;
const startsVisible = !shouldHideAtTop;
---

<header
  class="site-header"
  data-hide-at-top={shouldHideAtTop ? 'true' : 'false'}
  data-visible={startsVisible ? 'true' : 'false'}
  aria-hidden={startsVisible ? 'false' : 'true'}
  aria-label="Primary navigation"
  style={startsVisible ? 'opacity: 1; visibility: visible; transform: translate3d(0, 0, 0);' : undefined}
>
  <nav class="site-nav" aria-label="Main sections">
    {navItems.map((item) => (
      <a
        href={item.href}
        data-nav-match={item.match}
        class:list={['site-nav-link', { 'is-active': isActive(item) }]}
        aria-current={isActive(item) ? 'page' : undefined}
      >
        {item.label}
      </a>
    ))}
  </nav>
</header>

<div class="theme-switcher" aria-label="Theme switcher">
  <button class="theme-dot theme-dot-light" type="button" data-theme-choice="light" aria-label="Use light theme"></button>
  <button class="theme-dot theme-dot-dark" type="button" data-theme-choice="dark" aria-label="Use dark theme"></button>
</div>

<script is:inline>
  (() => {
    const storageKey = 'zhao-portfolio-theme';
    const getStoredTheme = () => {
      try {
        return localStorage.getItem(storageKey) === 'light' ? 'light' : 'dark';
      } catch {
        return 'dark';
      }
    };

    const setStoredTheme = (theme) => {
      try {
        localStorage.setItem(storageKey, theme);
      } catch {
        // Storage may be unavailable in private contexts.
      }
    };

    const syncThemeControls = (theme) => {
      document.querySelectorAll('[data-theme-choice]').forEach((button) => {
        const isActive = button.dataset.themeChoice === theme;
        button.classList.toggle('is-active', isActive);
        button.setAttribute('aria-pressed', isActive ? 'true' : 'false');
      });
    };

    const applyTheme = (theme) => {
      document.documentElement.dataset.theme = theme;
      document.documentElement.style.colorScheme = theme === 'light' ? 'light' : 'dark';
      syncThemeControls(theme);
    };

    const makeThemeReveal = (button, theme) => {
      const rect = button.getBoundingClientRect();
      const originX = rect.left + rect.width / 2;
      const originY = rect.top + rect.height / 2;
      const radius = Math.ceil(Math.hypot(
        Math.max(originX, window.innerWidth - originX),
        Math.max(originY, window.innerHeight - originY)
      ));
      const overlay = document.createElement('div');
      overlay.className = 'theme-reveal';
      overlay.style.setProperty('--theme-reveal-x', `${originX}px`);
      overlay.style.setProperty('--theme-reveal-y', `${originY}px`);
      overlay.style.setProperty('--theme-reveal-radius', `${radius}px`);
      overlay.style.background = theme === 'light' ? '#ffffff' : '#050505';
      document.body.appendChild(overlay);

      window.requestAnimationFrame(() => {
        overlay.dataset.active = 'true';
      });

      let isComplete = false;
      const completeReveal = () => {
        if (isComplete) return;
        isComplete = true;
        applyTheme(theme);
        setStoredTheme(theme);
        overlay.remove();
      };

      overlay.addEventListener('transitionend', completeReveal, { once: true });
      window.setTimeout(completeReveal, 820);
    };

    applyTheme(getStoredTheme());

    document.querySelectorAll('[data-theme-choice]').forEach((button) => {
      button.addEventListener('click', () => {
        const theme = button.dataset.themeChoice;
        if (!theme || document.documentElement.dataset.theme === theme) return;
        makeThemeReveal(button, theme);
      });
    });

    const syncSiteHeaderActiveState = () => {
      const links = Array.from(document.querySelectorAll('.site-nav-link'));
      const activeMatch = window.location.pathname.replace(/\/$/, '') || '/';

      links.forEach((link) => {
        const isActive = link.dataset.navMatch === activeMatch;
        link.classList.toggle('is-active', isActive);
        if (isActive) {
          link.setAttribute('aria-current', 'page');
        } else {
          link.removeAttribute('aria-current');
        }
      });
    };

    let hideTimer = 0;
    const setHeaderVisibility = (header, isVisible) => {
      const nav = header.querySelector('.site-nav');
      window.clearTimeout(hideTimer);

      header.dataset.visible = isVisible ? 'true' : 'false';
      header.setAttribute('aria-hidden', isVisible ? 'false' : 'true');
      header.style.opacity = isVisible ? '1' : '0';
      header.style.transform = isVisible ? 'translate3d(0, 0, 0)' : 'translate3d(0, calc(-100% - 0.75rem), 0)';
      if (nav) {
        nav.style.pointerEvents = isVisible ? 'auto' : 'none';
      }

      if (isVisible) {
        header.style.visibility = 'visible';
        return;
      }

      hideTimer = window.setTimeout(() => {
        if (header.dataset.visible === 'false') {
          header.style.visibility = 'hidden';
        }
      }, 260);
    };

    const syncSiteHeaderVisibility = () => {
      const header = document.querySelector('.site-header');
      if (!header) return;
      const scrollTop = window.pageYOffset || document.documentElement.scrollTop || document.body.scrollTop || 0;
      const isVisible = header.dataset.hideAtTop !== 'true' || scrollTop > 28;
      setHeaderVisibility(header, isVisible);
    };

    let frameId = 0;
    const syncSiteHeader = () => {
      if (frameId) {
        window.cancelAnimationFrame(frameId);
      }
      frameId = window.requestAnimationFrame(() => {
        frameId = 0;
        syncSiteHeaderActiveState();
        syncSiteHeaderVisibility();
      });
    };

    syncSiteHeaderActiveState();
    syncSiteHeaderVisibility();
    window.addEventListener('hashchange', syncSiteHeader);
    window.addEventListener('popstate', syncSiteHeader);
    window.addEventListener('scroll', syncSiteHeader, { passive: true });
    window.addEventListener('resize', syncSiteHeader, { passive: true });
    window.addEventListener('pageshow', syncSiteHeader);
  })();
</script>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 10040;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(1.65rem, 3.1vh, 2.15rem) clamp(1rem, 3vw, 2.5rem) 1rem;
    pointer-events: none;
    font-family: "Avenir Next", "Nunito Sans", "Helvetica Neue", Arial, var(--font-sans-cn), sans-serif;
    opacity: 0;
    visibility: hidden;
    transform: translate3d(0, calc(-100% - 0.75rem), 0);
    transition: opacity 220ms ease, transform 260ms cubic-bezier(0.16, 1, 0.3, 1), visibility 0ms linear 260ms;
  }

  .site-header[data-visible="true"] {
    opacity: 1;
    visibility: visible;
    transform: translate3d(0, 0, 0);
    transition-delay: 0ms;
  }

  .site-header[data-visible="true"] .site-nav {
    pointer-events: auto;
  }

  .site-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.12rem;
    max-width: calc(100vw - 2rem);
    overflow-x: auto;
    scrollbar-width: none;
    border: 1px solid rgba(142, 219, 53, 0.34);
    border-radius: 12px;
    background: rgba(8, 8, 8, 0.62);
    padding: 0.38rem;
    backdrop-filter: blur(20px);
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.34), inset 0 1px 0 rgba(255, 255, 255, 0.06);
    pointer-events: none;
  }

  .site-nav::-webkit-scrollbar {
    display: none;
  }

  .site-nav-link {
    display: flex;
    min-height: 2.65rem;
    align-items: center;
    justify-content: center;
    padding: 0.58rem 1rem;
    color: rgba(245, 245, 245, 0.78);
    text-decoration: none;
    border: 1px solid transparent;
    border-radius: 8px;
    white-space: nowrap;
    font-size: clamp(0.96rem, 1.16vw, 1.08rem);
    font-weight: 500;
    letter-spacing: 0;
    line-height: 1;
    transition: color 180ms ease, border-color 180ms ease, background 180ms ease, box-shadow 180ms ease, transform 180ms ease;
  }

  .site-nav-link:hover,
  .site-nav-link:focus-visible,
  .site-nav-link.is-active {
    color: #050505;
    border-color: rgba(142, 219, 53, 0.78);
    background: #8EDB35;
    box-shadow: 0 0 22px rgba(142, 219, 53, 0.22);
    outline: none;
    transform: translateY(-1px);
  }

  .theme-switcher {
    align-items: center;
    display: flex;
    gap: 0.54rem;
    position: fixed;
    right: max(1.18rem, calc(var(--site-frame-inset, 0.95rem) + 0.58rem));
    top: max(1.18rem, calc(var(--site-frame-inset, 0.95rem) + 0.58rem));
    z-index: 10050;
  }

  .theme-dot {
    appearance: none;
    border: 1px solid transparent;
    border-radius: 999px;
    box-shadow: none;
    cursor: pointer;
    display: block;
    height: 0.72rem;
    padding: 0;
    transition: border-color 160ms ease, transform 160ms ease, box-shadow 160ms ease;
    width: 0.72rem;
  }

  .theme-dot:hover,
  .theme-dot:focus-visible {
    outline: none;
    transform: scale(1.18);
  }

  .theme-dot-light {
    background: #ffffff;
  }

  .theme-dot-dark {
    background: #050505;
  }

  .theme-dot-light.is-active {
    border-color: #050505;
    box-shadow: 0 0 0 2px rgba(5, 5, 5, 0.08);
  }

  .theme-dot-light:not(.is-active) {
    border-color: transparent;
    box-shadow: none;
  }

  .theme-dot-dark.is-active {
    border-color: #ffffff;
    box-shadow: 0 0 0 2px rgba(255, 255, 255, 0.08);
  }

  .theme-dot-dark:not(.is-active) {
    border-color: transparent;
    box-shadow: none;
  }

  :global(.theme-reveal) {
    clip-path: circle(0 at var(--theme-reveal-x) var(--theme-reveal-y));
    inset: 0;
    pointer-events: none;
    position: fixed;
    transition: clip-path 680ms cubic-bezier(0.72, 0, 0.18, 1);
    z-index: 10080;
  }

  :global(.theme-reveal[data-active="true"]) {
    clip-path: circle(var(--theme-reveal-radius) at var(--theme-reveal-x) var(--theme-reveal-y));
  }

  @media (max-width: 760px) {
    .site-header {
      padding: max(0.72rem, env(safe-area-inset-top)) 0.62rem 0.62rem;
    }

    .site-nav {
      width: calc(100vw - 1.25rem);
      max-width: calc(100vw - 1.25rem);
      justify-content: flex-start;
      padding: 0.32rem;
      border-radius: 11px;
      scroll-padding-inline: 0.32rem;
      -webkit-overflow-scrolling: touch;
    }

    .site-nav-link {
      flex: 0 0 auto;
      min-height: 2.12rem;
      padding: 0.46rem 0.68rem;
      border-radius: 7px;
      font-size: 0.82rem;
    }

    .theme-switcher {
      gap: 0.48rem;
      right: max(0.8rem, calc(env(safe-area-inset-right) + 0.8rem));
      top: max(0.8rem, calc(env(safe-area-inset-top) + 0.8rem));
    }
  }
</style>
